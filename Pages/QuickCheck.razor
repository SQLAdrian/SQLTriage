    private async Task AutoExportQuickCheckResults()
    {
        var settings = UserSettings.GetSettings();
        if (!settings.AutoExportQuickCheckCsv && !settings.AutoExportQuickCheckPdf) return;
        if (State.Results.Count == 0) return;

        var outputDir = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "output");
        Directory.CreateDirectory(outputDir);
        var timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");

        if (settings.AutoExportQuickCheckCsv)
        {
            try
            {
                var csv = new System.Text.StringBuilder();
                csv.AppendLine("Instance,CheckId,CheckName,Category,Severity,Passed,ActualValue,ExpectedValue,Message,DurationMs,ExecutedAt");
                foreach (var r in State.Results)
                {
                    var msg = (r.Message ?? "").Replace("\"", "\"\"");
                    csv.AppendLine($"\"{r.InstanceName}\",\"{r.CheckId}\",\"{r.CheckName}\",\"{r.Category}\",\"{r.Severity}\",{r.Passed},{r.ActualValue},{r.ExpectedValue},\"{msg}\",{r.DurationMs},\"{r.ExecutedAt:o}\"");
                }
                var fileName = $"QuickCheck_{timestamp}.csv";
                await File.WriteAllTextAsync(Path.Combine(outputDir, fileName), csv.ToString());
                Toast.ShowInfo($"Audit Assessment CSV exported: {fileName}");
            }
            catch (Exception ex)
            {
                Toast.ShowError($"CSV export failed: {ex.Message}");
            }
        }

        if (settings.AutoExportQuickCheckPdf)
        {
            try
            {
                await Task.Delay(500); // let UI render final state
                if (!PrintSvc.IsAvailable)
                {
                    await PrintSvc.PrintViaBrowserAsync(JSRuntime);
                    Toast.ShowInfo("Browser print dialog opened for PDF export.");
                }
                else
                {
                    var fileName = $"QuickCheck_{timestamp}.pdf";
                    var qkEnv = ConnectionManager.GetConnection(State.SelectedConnectionId)?.Environment;
                    var qkWatermark = ServerEnvironment.RequiresWatermark(new[] { qkEnv });
                    if (qkWatermark)
                        await JSRuntime.InvokeVoidAsync("eval", "document.body.classList.add('has-draft-watermark');");
                    var (success, path, error) = await PrintSvc.PrintToPdfAsync(
                        fileName,
                        printBackgrounds: false,
                        orientation: Microsoft.Web.WebView2.Core.CoreWebView2PrintOrientation.Portrait);
                    if (qkWatermark)
                        await JSRuntime.InvokeVoidAsync("eval", "document.body.classList.remove('has-draft-watermark');");
                    if (success)
                        Toast.ShowInfo($"Audit Assessment PDF exported: {fileName}");
                }
            }
            catch (Exception ex)
            {
                Toast.ShowError($"PDF export failed: {ex.Message}");
            }
        }
    }

    // QuestPDF export of the audit (corpus) findings — deterministic, server-side; replaces the
    // browser-print path. Saves to .\output next to the exe.
    private async Task ExportQuestPdf()
    {
        try
        {
            if (State.Results.Count == 0) { Toast.ShowInfo("No results to export — run an assessment first."); return; }

            var cb      = UserSettings.GetColorBlindMode();
            var servers = State.Results.Select(r => r.InstanceName).Where(s => !string.IsNullOrEmpty(s))
                                       .Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s).ToList();
            var runId   = Guid.NewGuid().ToString("N")[..8];
            var nowUtc  = DateTime.UtcNow;
            var tz      = TimeZoneInfo.Local.StandardName;
            var scope   = servers.Count == 1 ? servers[0] : $"{servers.Count} servers";

            var serverSet = servers.ToHashSet(StringComparer.OrdinalIgnoreCase);
            var envs = ConnectionManager.GetConnections()
                .Where(c => c.GetServerList().Any(n => serverSet.Contains(n))).Select(c => c.Environment).ToList();
            var watermark = UserSettings.GetReportDraftWatermark()
                            && SQLTriage.Data.Models.ServerEnvironment.RequiresWatermark(envs);

            var report = new SQLTriage.Data.Services.FindingsReport
            {
                Meta = new SQLTriage.Data.Services.AssessmentMeta
                {
                    Title        = "Audit Assessment",
                    Company      = UserSettings.GetReportCompanyName(),
                    Subtitle     = servers.Count == 1 ? servers[0] : $"{servers.Count} servers · {string.Join(", ", servers.Take(6))}",
                    Engine       = "Corpus audit checks",
                    GeneratedUtc = nowUtc.ToString("yyyy-MM-ddTHH:mmZ"),
                    TimezoneId   = tz,
                    RunId        = runId,
                    ColorBlind   = cb,
                    Watermark    = watermark,
                    FooterMeta   = $"SQLTriage — Audit Assessment — {scope} — {nowUtc:yyyy-MM-ddTHH:mmZ} ({tz}) — Run {runId}",
                },
                Stats =
                {
                    new() { Label = "PASSED",   Value = PassedCount.ToString(),       Color = SQLTriage.Data.Services.AssessmentPdf.Pass(cb) },
                    new() { Label = "FINDINGS", Value = FailedCount.ToString(),       Color = SQLTriage.Data.Services.AssessmentPdf.Fail(cb) },
                    new() { Label = "ERRORS",   Value = ErrorCount.ToString(),        Color = SQLTriage.Data.Services.AssessmentPdf.Fail(cb) },
                    new() { Label = "SERVERS",  Value = State.ServersTested.ToString(), Color = "#2563eb" },
                },
            };

            foreach (var r in State.Results)
            {
                var st = (r.IsCorrupted || !string.IsNullOrEmpty(r.ErrorMessage)) ? SQLTriage.Data.Services.FindingState.Error
                       : IsSkipped(r)                                              ? SQLTriage.Data.Services.FindingState.Skipped
                       : r.Passed                                                  ? SQLTriage.Data.Services.FindingState.Pass
                       :                                                             SQLTriage.Data.Services.FindingState.Fail;
                var detail = !string.IsNullOrEmpty(r.ErrorMessage) ? r.ErrorMessage
                           : !string.IsNullOrEmpty(r.Message)      ? r.Message
                           :                                          (r.Description ?? "");
                report.Findings.Add(new SQLTriage.Data.Services.FindingRow
                {
                    State = st, Name = r.CheckName, Category = r.Category, Severity = r.Severity,
                    Server = r.InstanceName, Detail = detail,
                });
            }

            var bytes = await Task.Run(() => SQLTriage.Data.Services.AssessmentPdf.BuildFindingsReport(report));
            var dir   = System.IO.Path.Combine(AppContext.BaseDirectory, "output");
            System.IO.Directory.CreateDirectory(dir);
            var label = (servers.Count == 1 ? servers[0] : $"{servers.Count}servers").Replace("\\", "_").Replace("/", "_");
            var path  = System.IO.Path.Combine(dir, $"AuditAssessment_{label}_{nowUtc:yyyyMMdd_HHmmssZ}_{runId}.pdf");
            await System.IO.File.WriteAllBytesAsync(path, bytes);
            Toast.ShowSuccess("PDF exported", System.IO.Path.GetFileName(path));
        }
        catch (Exception ex)
        {
            Toast.ShowError("PDF export failed", ex.Message);
        }
    }

