    // When true, the next run reloads the check catalog from sql-checks.json
    // first — picks up a corpus regeneration without an app restart (the
    // catalog is otherwise read once at startup by CheckRepositoryService).
    private bool _forceFresh;

    private async Task RunChecks()
    {
        if (!RbacService.HasPermission(UserState.Role, "execute_checks"))
        {
            Toast.ShowWarning("Insufficient permissions. Operator role required to run checks.");
            return;
        }
        if (_forceFresh)
        {
            await CheckRepo.LoadChecksAsync();
            State.AddDiagEntry($"=== Catalog reloaded: {CheckRepo.Checks.Count} checks ===", "info");
        }
        CheckExecutor.ClearAllResults();
        State.IsRunning       = true;
        State.Progress        = 0;
        State.ProgressMessage = "Starting...";
        State.Results.Clear();
        State.ServerSummaries.Clear();
        State.DiagLog.Clear();
        State.ExecutionTime   = DateTime.Now;
        State.ServersTested   = 0;
        // Re-merge imported sp_BLITZ findings immediately so they stay visible THROUGHOUT
        // the run, not just after it completes. Clearing State.Results above (and the
        // State.Results = allResults swap at the end) would otherwise make the sp_BLITZ
        // section flash-then-vanish for the whole run, and disappear entirely if the run
        // errors before the end-of-run re-merge.
        await MergeSpBlitzFindings();
        State.NotifyStateChanged();

        var overallStart = DateTime.UtcNow;
        State.AddDiagEntry("=== Audit Assessment started ===", "info");

        try
        {
            var targets = new List<(ServerConnection Connection, string Server)>();

            if (State.RunAllServers)
            {
                foreach (var conn in EnabledConnections)
                    foreach (var server in conn.GetServerList())
                        targets.Add((conn, server));
            }
            else
            {
                var connection = ConnectionManager.GetConnection(State.SelectedConnectionId);
                if (connection == null)
                {
                    State.StatusMessage = "Connection not found.";
                    State.StatusClass   = "error";
                    State.AddDiagEntry("ERROR: Connection not found", "error");
                    return;
                }
                foreach (var server in connection.GetServerList())
                    targets.Add((connection, server));
            }

            if (targets.Count == 0)
            {
                State.StatusMessage = "No servers to check.";
                State.StatusClass   = "error";
                State.AddDiagEntry("ERROR: No servers to check", "error");
                return;
            }

            State.AddDiagEntry($"Targets: {targets.Count} server(s)", "info");

            Func<SqlCheck, bool> filter = c => true;

            var checksToRun = CheckRepo.GetEnabledChecks().Where(filter).ToList();
            State.AddDiagEntry($"Checks to execute per server: {checksToRun.Count}", "info");

            foreach (var g in checksToRun.GroupBy(c => c.Category).OrderBy(g => g.Key))
                State.AddDiagEntry($"  Category '{g.Key}': {g.Count()} checks", "info");
            foreach (var g in checksToRun.GroupBy(c => c.Severity).OrderBy(g => g.Key))
                State.AddDiagEntry($"  Severity '{g.Key}': {g.Count()} checks", "info");
            foreach (var g in checksToRun.GroupBy(c => c.ExecutionType ?? "scalar").OrderBy(g => g.Key))
                State.AddDiagEntry($"  ExecutionType '{g.Key}': {g.Count()} checks", "info");

            var allResults    = new List<CheckResult>();
            int totalTargets  = targets.Count;
            int completedTargets = 0;
            var resultsLock = new object();

            // Per-target work. Shared-state mutations (summaries, results, progress) are
            // guarded by resultsLock so the parallel path is safe; CheckExecutor itself
            // throttles per-instance queries and rents from the shared pool, so total
            // concurrency stays bounded (servers × per-instance throttle ≤ pool cap).
            async Task RunOneTarget(ServerConnection conn, string server)
            {
                lock (resultsLock)
                {
                    State.ProgressMessage = $"Checking {server}...";
                    State.AddDiagEntry($"--- Connecting to {server} ---", "info");
                }
                State.NotifyStateChanged();

                try
                {
                    var summary = await CheckExecutor.ExecuteChecksAsync(conn, server, filter);
                    var serverResults = CheckExecutor.GetResults(server, 1000);
                    lock (resultsLock)
                    {
                        State.ServerSummaries.Add(summary);
                        State.AddDiagEntry($"--- {server} complete: {summary.Passed} pass, {summary.Failed} fail, {summary.Errors} err ({summary.Duration.TotalSeconds:F1}s) ---", "info");
                        allResults.AddRange(serverResults);
                    }
                    Toast.ShowInfo($"Audit Assessment: {server} — {summary.Passed} pass, {summary.Failed} fail ({summary.Duration.TotalSeconds:F1}s)");
                }
                catch (Exception ex)
                {
                    lock (resultsLock)
                    {
                        State.AddDiagEntry($"ERROR on {server}: {ex.Message}", "error");
                        State.ServerSummaries.Add(new CheckExecutionSummary
                        {
                            InstanceName  = server,
                            StartedAt     = DateTime.UtcNow,
                            CompletedAt   = DateTime.UtcNow,
                            Errors        = CheckRepo.GetEnabledChecks().Count
                        });
                    }
                }

                lock (resultsLock)
                {
                    completedTargets++;
                    State.Progress      = (int)((double)completedTargets / totalTargets * 100);
                    State.ServersTested = completedTargets;
                }
                State.NotifyStateChanged();
            }

            if (_parallelMode && targets.Count > 1)
            {
                // Start each server concurrently, staggered by the configured delay.
                var tasks = new List<Task>();
                for (int i = 0; i < targets.Count; i++)
                {
                    var (conn, server) = targets[i];
                    var startDelay = TimeSpan.FromSeconds(_parallelDelaySeconds * i);
                    tasks.Add(Task.Run(async () =>
                    {
                        if (startDelay > TimeSpan.Zero) await Task.Delay(startDelay);
                        await RunOneTarget(conn, server);
                    }));
                }
                await Task.WhenAll(tasks);
            }
            else
            {
                foreach (var (conn, server) in targets)
                    await RunOneTarget(conn, server);
            }

            State.Results = allResults;
            State.HasRun  = true;

            var totalDuration     = DateTime.UtcNow - overallStart;
            State.ExecutionDuration = $"{totalDuration.TotalSeconds:F1}s";
            State.Categories = State.Results.Select(r => r.Category).Distinct().OrderBy(c => c).ToList();

            // Re-merge imported sp_BLITZ findings — the run cleared State.Results above.
            await MergeSpBlitzFindings();

            if (State.Results.Count > 0)
            {
                State.StatusMessage = $"Audit Assessment completed: {PassedCount} passed, {FailedCount} failed, {ErrorCount} errors across {State.ServersTested} server(s)";
                State.StatusClass   = FailedCount > 0 || ErrorCount > 0 ? "warning" : "success";
            }
            else
            {
                State.StatusMessage = "No checks were executed. Make sure checks are enabled in sql-checks.json";
                State.StatusClass   = "warning";
            }

            State.AddDiagEntry($"=== Complete: {State.Results.Count} total results in {State.ExecutionDuration} ===", "info");

            var overallDuration = DateTime.UtcNow - overallStart;
            var anyFailures = FailedCount > 0 || ErrorCount > 0;
            AuditLog.LogScriptExecution("QuickCheck", string.Join(",", targets.Select(t => t.Server)),
                !anyFailures, overallDuration,
                anyFailures ? $"{FailedCount} failed, {ErrorCount} errors" : null);

            await AutoExportQuickCheckResults();
        }
        catch (Exception ex)
        {
            State.StatusMessage = $"Error running checks: {ex.Message}";
            State.StatusClass   = "error";
            State.AddDiagEntry($"FATAL ERROR: {ex.Message}", "error");
            System.Diagnostics.Debug.WriteLine($"[QuickCheck] Error: {ex}");
        }
        finally
        {
            State.IsRunning       = false;
            State.Progress        = 100;
            State.ProgressMessage = "Complete";
            State.NotifyStateChanged();
        }
    }

    private string GetRowClass(CheckResult result)
    {
        if (!string.IsNullOrEmpty(result.ErrorMessage)) return "row-error";
        return result.Passed ? "row-passed" : "row-failed";
    }

    private string GetSeverityClass(string severity) =>
        severity?.ToLower() switch
        {
            "critical" => "severity-critical",
            "warning"  => "severity-warning",
            "info"     => "severity-info",
            _          => "severity-default"
        };
}

