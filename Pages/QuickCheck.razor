<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/audit"

@using SQLTriage.Data
@using SQLTriage.Data.Models
@using SQLTriage.Data.Caching
@using SQLTriage.Data.Services.Licensing
@using System.IO
@inject IBundleAccessor Bundle
@inject SpBlitzCache BlitzCache
@inject AuditOutputScanner OutputScanner
@inject CheckRepositoryService CheckRepo
@inject CheckExecutionService CheckExecutor
@inject ServerConnectionManager ConnectionManager
@inject UserSettingsService UserSettings
@inject QuickCheckStateService State
@inject SQLTriage.Data.Services.PrintService PrintSvc
@inject SQLTriage.Data.Services.ReportPageConfigService ReportPageCfg
@inject SQLTriage.Data.ToastService Toast
@inject SQLTriage.Data.Services.KeyboardShortcutService ShortcutSvc
@inject IJSRuntime JSRuntime
@inject SQLTriage.Data.Services.AppUserState UserState
@inject AuditLogService AuditLog
@implements IDisposable

<PdfExportModal @ref="_pdfModal"
    Title="Export Results to PDF"
    DefaultLandscape="false"
    DefaultBackgrounds="false"
    OnConfirm="OnPdfConfirmed" />

<SectionEditorModal IsVisible="_editingSection != null"
    Section="_editingSection"
    NativeKeys="_availableNativeKeys"
    AvailableFields="_qcFields"
    OnSave="HandleSectionSaved"
    OnCancel="() => _editingSection = null" />

<AddSectionModal IsVisible="_showAddSection"
    NativeKeys="_availableNativeKeys"
    OnAdd="HandleSectionAdded"
    OnCancel="() => _showAddSection = false" />

@using SQLTriage.Components.Shared

@if (!_initialized)
{
    <PageLoadingSpinner Message="Loading Audit Assessment..." />
}
else
{
<div class="quickcheck-page">
    @* FreeStateBanner is now rendered once at MainLayout level *@
    @if (!string.IsNullOrEmpty(CheckRepo.LoadError))
    {
        <div class="qc-loaderror-banner" role="alert">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span><strong>Check catalog failed to load.</strong> @CheckRepo.LoadError
            Results shown may be stale — no fresh checks can run until this is resolved.</span>
        </div>
    }
    <div class="page-header">
        <div>
            <h2>Audit Assessment</h2>
            <p class="page-description">
                Run SQL health checks from sql-checks.json against configured servers.
            </p>
        </div>
        <div class="header-actions">
            <div class="header-stats">
                <span class="stat-pill">@EnabledChecksCount enabled checks</span>
                <span class="stat-pill">@EnabledServersCount enabled servers</span>
            </div>
            <button class="btn btn-sm btn-toggle-diag @(ShowDiagnosticPane ? "active" : "")"
                    @onclick="ToggleDiagnosticPane" title="Toggle diagnostic output">
                Diagnostics @(ShowDiagnosticPane ? "ON" : "OFF")
            </button>
        </div>
    </div>

    <div class="qc-layout @(ShowDiagnosticPane ? "with-diag" : "")">
        <!-- Main Content -->
        <div class="qc-main">
            <!-- Server Selection -->
            <ReportSectionWrapper Section="@GetSection("server-selection")" EditMode="_editMode"
                IsFirst="@IsFirstSection("server-selection")" IsLast="@IsLastSection("server-selection")"
                OnMoveUp="s => MoveSection(s, -1)" OnMoveDown="s => MoveSection(s, 1)"
                OnEdit="s => _editingSection = s" OnDelete="s => DeleteSection(s)"
                OnToggle="s => ToggleSection(s)">
            <div class="server-selection">
                <div class="server-selection-header">
                    <label>Target Servers:</label>
                </div>

                @if (Connections.Count == 0)
                {
                    <div class="qc-no-servers">
                        <i class="fa-solid fa-server qc-no-servers-icon"></i>
                        <div class="qc-no-servers-msg">No server connections configured.</div>
                        <a href="/servers" class="qc-add-server-link">
                            <i class="fa-solid fa-plus"></i> Add Server
                        </a>
                    </div>
                }
                else
                {
                    <ServerSelector AllowAllScope="true"
                        Items="@ConnectionItems"
                        SelectedId="@(State.RunAllServers ? null : State.SelectedConnectionId)"
                        SelectedIdChanged="@OnConnectionSelected" />
                }

                @* Run-mode control — only meaningful for multi-server (All scope) runs.
                   Mirrors Raw Diagnostics: sequential vs parallel + per-server stagger.
                   Parallel runs stay under the shared pool cap (routed through it). *@
                @if (State.RunAllServers && EnabledConnections.Count > 1)
                {
                    <div class="run-all-group">
                        <div class="run-mode-toggle">
                            <button class="run-mode-btn @(_parallelMode ? "" : "active")"
                                    @onclick="() => _parallelMode = false" disabled="@State.IsRunning"
                                    title="Run each server one at a time">
                                <i class="fa-solid fa-list-ol"></i> Sequential
                            </button>
                            <button class="run-mode-btn @(_parallelMode ? "active" : "")"
                                    @onclick="() => _parallelMode = true" disabled="@State.IsRunning"
                                    title="Start all servers concurrently, staggered by delay">
                                <i class="fa-solid fa-bolt"></i> Parallel
                            </button>
                        </div>
                        @if (_parallelMode)
                        {
                            <div class="delay-input-group" title="Seconds to wait before starting each subsequent server">
                                <i class="fa-solid fa-stopwatch" style="color:var(--text-secondary);font-size:12px;"></i>
                                <input type="number" min="0" max="300" step="1"
                                       @bind="_parallelDelaySeconds"
                                       style="width:52px;padding:3px 6px;border-radius:4px;border:1px solid var(--border);background:var(--bg-secondary);color:var(--text-primary);font-size:12px;"
                                       disabled="@State.IsRunning" />
                                <span style="font-size:11px;color:var(--text-muted);">s delay</span>
                            </div>
                        }
                    </div>
                }

                <div class="action-row">
                    <button class="btn btn-primary btn-run" @onclick="RunChecks"
                            disabled="@(State.IsRunning || (!State.RunAllServers && string.IsNullOrEmpty(State.SelectedConnectionId)) || (State.RunAllServers && EnabledConnections.Count == 0))">
                        @if (State.IsRunning)
                        {
                            <span>Running...</span>
                        }
                        else
                        {
                            <span><i class="fa-solid fa-magnifying-glass"></i> Run Audit Assessment</span>
                        }
                    </button>

                    @if (State.Results.Count > 0)
                    {
                        <button class="btn btn-secondary" @onclick="ClearResults">Clear Results</button>
                        <button class="btn btn-secondary" @onclick="PrintResults"><i class="fa-solid fa-file-pdf"></i> Export PDF</button>
                    }

                    <label class="qc-force-fresh" title="Reload the check catalog from sql-checks.json before running. Use after a corpus regeneration to pick up new/recategorised checks without restarting the app.">
                        <input type="checkbox" @bind="_forceFresh" disabled="@State.IsRunning" />
                        <span>Force fresh (reload catalog)</span>
                    </label>

                </div>
            </div>
            </ReportSectionWrapper>

            @if (ShowSpBlitzPrompt)
            {
                <div class="qc-spblitz-prompt" role="status">
                    <div class="qc-spblitz-prompt-head">
                        <i class="fa-solid fa-file-import qc-spblitz-prompt-icon"></i>
                        <div>
                            <strong>No sp_BLITZ data imported yet.</strong>
                            <p class="qc-spblitz-prompt-text">
                                On the Free tier you can run Brent Ozar's
                                <code>sp_BLITZ</code> on your SQL Server, export the results to CSV,
                                and import them here to see findings alongside the live audit checks.
                            </p>
                        </div>
                        <div style="display:flex;gap:8px;flex-shrink:0;">
                            @if (_detectedBlitzFiles.Count > 0)
                            {
                                <button class="btn btn-success btn-sm" @onclick="ImportDetectedBlitzFiles" disabled="@_importingDetected"
                                        title="@DetectedBlitzTooltip">
                                    @if (_importingDetected)
                                    {
                                        <span>Importing…</span>
                                    }
                                    else
                                    {
                                        <span><i class="fa-solid fa-folder-open"></i> Import @_detectedBlitzFiles.Count found in output</span>
                                    }
                                </button>
                            }
                            <button class="btn btn-primary btn-sm" @onclick="ToggleSpBlitzImport">
                                @(_showSpBlitzImport ? "Hide import" : "Import sp_BLITZ CSV")
                            </button>
                        </div>
                    </div>

                    @if (_showSpBlitzImport)
                    {
                        <SpBlitzDropZone OnImportCompleted="OnSpBlitzImported" />
                    }
                </div>
            }

            @if (State.IsRunning)
            {
                <div class="progress-section">
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: @State.Progress%"></div>
                    </div>
                    <span class="progress-text">
                        @State.ProgressMessage (@State.Progress%)
                    </span>
                </div>
            }

            @if (State.Results.Count > 0)
            {
                <ReportSectionWrapper Section="@GetSection("summary-cards")" EditMode="_editMode"
                    IsFirst="@IsFirstSection("summary-cards")" IsLast="@IsLastSection("summary-cards")"
                    OnMoveUp="s => MoveSection(s, -1)" OnMoveDown="s => MoveSection(s, 1)"
                    OnEdit="s => _editingSection = s" OnDelete="s => DeleteSection(s)"
                    OnToggle="s => ToggleSection(s)">
                <!-- Execution Info -->
                <div class="execution-info">
                    <span>Executed at @State.ExecutionTime.ToString("HH:mm:ss") | Duration: @State.ExecutionDuration</span>
                    <span>@State.ServersTested server(s) tested</span>
                </div>

                <!-- Per-Server Summary -->
                @if (State.ServerSummaries.Count > 0)
                {
                    <div class="server-summaries">
                        @foreach (var summary in State.ServerSummaries)
                        {
                            <div class="server-summary-card @(summary.Failed > 0 ? "has-failures" : summary.Errors > 0 ? "has-errors" : "all-passed")">
                                <div class="server-summary-name">@summary.InstanceName</div>
                                <div class="server-summary-stats">
                                    <span class="ss-passed" title="Passed"><i class="fa-solid fa-check"></i> @summary.Passed</span>
                                    <span class="ss-failed" title="Failed"><i class="fa-solid fa-xmark"></i> @summary.Failed</span>
                                    <span class="ss-errors" title="Errors"><i class="fa-solid fa-triangle-exclamation"></i> @summary.Errors</span>
                                    <span class="ss-duration" title="Duration">@summary.Duration.TotalSeconds.ToString("F1")s</span>
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- Clickable Overall Summary Cards -->
                <div class="results-summary">
                    <div class="summary-card passed @(State.SelectedFilter == "passed" ? "active-filter" : "")"
                         @onclick='() => SetFilterFromCard("passed")'>
                        <span class="summary-icon"><i class="fa-solid fa-check"></i></span>
                        <span class="summary-count">@PassedCount</span>
                        <span class="summary-label">Passed</span>
                    </div>
                    <div class="summary-card failed @(State.SelectedFilter == "failed" ? "active-filter" : "")"
                         @onclick='() => SetFilterFromCard("failed")'>
                        <span class="summary-icon"><i class="fa-solid fa-xmark"></i></span>
                        <span class="summary-count">@FailedCount</span>
                        <span class="summary-label">Failed</span>
                    </div>
                    <div class="summary-card errors @(State.SelectedFilter == "errors" ? "active-filter" : "")"
                         @onclick='() => SetFilterFromCard("errors")'>
                        <span class="summary-icon"><i class="fa-solid fa-triangle-exclamation"></i></span>
                        <span class="summary-count">@ErrorCount</span>
                        <span class="summary-label">Errors</span>
                    </div>
                    @if (SkippedCount > 0)
                    {
                        <div class="summary-card skipped @(State.SelectedFilter == "skipped" ? "active-filter" : "")"
                             @onclick='() => SetFilterFromCard("skipped")'>
                            <span class="summary-icon"><i class="fa-solid fa-forward"></i></span>
                            <span class="summary-count">@SkippedCount</span>
                            <span class="summary-label">Skipped</span>
                        </div>
                    }
                    <div class="summary-card total @(State.SelectedFilter == "all" ? "active-filter" : "")"
                         @onclick='() => SetFilterFromCard("all")'>
                        <span class="summary-icon"><i class="fa-solid fa-clipboard-list"></i></span>
                        <span class="summary-count">@State.Results.Count</span>
                        <span class="summary-label">Total</span>
                    </div>
                </div>
                </ReportSectionWrapper>

                <ReportSectionWrapper Section="@GetSection("results-grid")" EditMode="_editMode"
                    IsFirst="@IsFirstSection("results-grid")" IsLast="@IsLastSection("results-grid")"
                    OnMoveUp="s => MoveSection(s, -1)" OnMoveDown="s => MoveSection(s, 1)"
                    OnEdit="s => _editingSection = s" OnDelete="s => DeleteSection(s)"
                    OnToggle="s => ToggleSection(s)">
                <!-- Results Filter -->
                <div class="results-filter">
                    <label>Status:</label>
                    <select @bind="State.SelectedFilter" class="filter-select">
                        <option value="all">All (@State.Results.Count)</option>
                        <option value="passed">Passed (@PassedCount)</option>
                        <option value="failed">Failed (@FailedCount)</option>
                        <option value="errors">Errors (@ErrorCount)</option>
                        @if (SkippedCount > 0)
                        {
                            <option value="skipped">Skipped (@SkippedCount)</option>
                        }
                    </select>
                    <label>Severity:</label>
                    <select @bind="State.SelectedSeverity" class="filter-select">
                        <option value="">All Severities</option>
                        <option value="Critical">Critical</option>
                        <option value="Warning">Warning</option>
                        <option value="Info">Info</option>
                    </select>
                    <label>Category:</label>
                    <select @bind="State.SelectedCategory" class="filter-select">
                        <option value="">All Categories</option>
                        @foreach (var cat in State.Categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                    <label>Server:</label>
                    <select @bind="State.SelectedServer" class="filter-select">
                        <option value="">All Servers</option>
                        @foreach (var srv in ServersInResults)
                        {
                            <option value="@srv">@srv</option>
                        }
                    </select>
                    <span class="filter-count">@FilteredResults.Count() results</span>
                </div>

                <!-- Results Grid -->
                <div class="results-grid">
                    <table class="results-table">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Server</th>
                                <th>Check</th>
                                <th>Category</th>
                                <th>Severity</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in FilteredResults)
                            {
                                var isExpanded = _expandedResults.Contains(result.CheckId + result.InstanceName);
                                var hasError   = !string.IsNullOrEmpty(result.ErrorMessage);
                                var hasMsg     = !string.IsNullOrEmpty(result.Message);
                                var hasRec     = !string.IsNullOrEmpty(result.RecommendedAction);
                                var hasDesc    = !string.IsNullOrEmpty(result.Description);
                                var anyDetail  = hasError || hasMsg || hasRec || hasDesc;
                                <tr class="@GetRowClass(result)" @onclick="() => ToggleExpandResult(result.CheckId + result.InstanceName)">
                                    <td class="status-cell">
                                        @if (result.IsCorrupted)
                                        {
                                            <span class="status-badge corrupted" title="@result.ErrorMessage"><i class="fa-solid fa-shield-halved"></i> Corrupted</span>
                                        }
                                        else if (!string.IsNullOrEmpty(result.ErrorMessage))
                                        {
                                            <span class="status-badge error"><i class="fa-solid fa-triangle-exclamation"></i> Error</span>
                                        }
                                        else if (IsSkipped(result))
                                        {
                                            <span class="status-badge skipped" title="@result.Message"><i class="fa-solid fa-forward"></i> Skip</span>
                                        }
                                        else if (result.Passed)
                                        {
                                            <span class="status-badge passed"><i class="fa-solid fa-check"></i> Pass</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge failed"><i class="fa-solid fa-xmark"></i> Fail</span>
                                        }
                                    </td>
                                    <td class="server-cell">@result.InstanceName</td>
                                    <td class="check-name">
                                        <strong>@result.CheckName</strong>
                                        <br />
                                        <small class="check-id">@result.CheckId</small>
                                    </td>
                                    <td><span class="category-badge">@result.Category</span></td>
                                    <td>
                                        <span class="severity-badge @GetSeverityClass(result.Severity)">
                                            @result.Severity
                                        </span>
                                    </td>
                                    <td class="description-cell">@result.Description</td>
                                </tr>
                                @if (isExpanded && anyDetail)
                                {
                                    <tr class="expanded-row">
                                        <td colspan="8">
                                            <div class="expanded-detail">
                                                @if (hasError)
                                                {
                                                    @* Surface the underlying SqlException so operators don't have to grep app-.log. *@
                                                    <div class="detail-section detail-section--error">
                                                        <strong>Error:</strong>
                                                        <pre class="detail-error-text">@result.ErrorMessage</pre>
                                                    </div>
                                                }
                                                @if (hasMsg && !hasError)
                                                {
                                                    <div class="detail-section">
                                                        <strong>Message:</strong> @result.Message
                                                    </div>
                                                }
                                                @if (hasDesc)
                                                {
                                                    <div class="detail-section">
                                                        <strong>Description:</strong> @result.Description
                                                    </div>
                                                }
                                                @if (hasRec)
                                                {
                                                    <div class="detail-section">
                                                        <strong>Recommended Action:</strong> @result.RecommendedAction
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                </ReportSectionWrapper>
            }
            else if (!State.IsRunning && State.HasRun)
            {
                <div class="no-checks">
                    <p>No checks were executed. Make sure sql-checks.json is loaded with enabled checks.</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(State.StatusMessage))
            {
                <div class="status-message @State.StatusClass" role="status">
                    @State.StatusMessage
                </div>
            }
        </div>

        <!-- Diagnostic Output Pane -->
        @if (ShowDiagnosticPane)
        {
            <div class="qc-diag-pane">
                <div class="diag-header">
                    <span>Diagnostic Output</span>
                    <div class="diag-header-actions">
                        <button class="btn btn-sm" @onclick="() => State.ClearDiagLog()" title="Clear log">Clear</button>
                        <button class="btn btn-sm" @onclick="ToggleDiagnosticPane" title="Close pane">X</button>
                    </div>
                </div>
                <div class="diag-scroll" @ref="_diagScrollRef">
                    @foreach (var entry in State.DiagLog)
                    {
                        <div class="diag-entry @entry.Level">
                            <span class="diag-time">@entry.Timestamp.ToString("HH:mm:ss.fff")</span>
                            <span class="diag-msg">@entry.Message</span>
                        </div>
                    }
                    @if (State.DiagLog.Count == 0)
                    {
                        <div class="diag-empty">Run a check to see diagnostic output here.</div>
                    }
                </div>
            </div>
        }
    </div>
</div>
}

@code {
    // Page-local UI only — not worth persisting across navigation
    private PdfExportModal   _pdfModal       = default!;
    private ElementReference _diagScrollRef;
    private HashSet<string>  _expandedResults = new();
    private bool             ShowDiagnosticPane;
    private bool             _disposed;
    private bool             _initialized;

    // ── Report Page Editor ────────────────────────────────────────────────
    private const bool        _editMode = false;
    private List<ReportSection> _sections          = new();
    private ReportSection?    _editingSection;
    private bool              _showAddSection;
    private ReportPageDefinition? _pageDef;

    private static readonly List<string> AllNativeKeys =
        new() { "server-selection", "summary-cards", "results-grid", "diagnostics" };

    private static readonly List<ReportFieldInfo> _qcFields = new()
    {
        new() { Name = "CheckId",          Type = "string",   Description = "Unique identifier for the check",                     IsKey = true  },
        new() { Name = "DisplayName",      Type = "string",   Description = "Human-readable check name",                          IsKey = false },
        new() { Name = "Category",         Type = "string",   Description = "Check category (e.g. Security, Performance)",         IsKey = false },
        new() { Name = "Severity",         Type = "string",   Description = "Finding severity: Critical, Warning, Info, Pass",     IsKey = false },
        new() { Name = "Result",           Type = "string",   Description = "Raw result value or finding text",                    IsKey = false },
        new() { Name = "Details",          Type = "string",   Description = "Extended description or recommendation",              IsKey = false },
        new() { Name = "ServerName",       Type = "string",   Description = "SQL Server instance that produced this result",       IsKey = true  },
        new() { Name = "RunDateUtc",       Type = "datetime", Description = "UTC timestamp when the check was executed",           IsKey = false },
        new() { Name = "IsPass",           Type = "bit",      Description = "1 if the check passed, 0 if it raised a finding",     IsKey = false },
        new() { Name = "ImplementationType", Type = "string", Description = "How the fix should be applied (e.g. Script, Config)", IsKey = false },
        new() { Name = "SqlQuery",         Type = "string",   Description = "Suggested remediation SQL, if available",             IsKey = false },
    };

    private List<string> _availableNativeKeys =>
        AllNativeKeys.Where(k => !_sections.Any(s => s.NativeKey == k && s.SectionType == "native")).ToList();

    private ReportSection GetSection(string nativeKey)
    {
        var s = _sections.FirstOrDefault(x => x.NativeKey == nativeKey && x.SectionType == "native");
        return s ?? new ReportSection { NativeKey = nativeKey, Title = nativeKey, SectionType = "native", Enabled = true };
    }

    private bool IsFirstSection(string nativeKey)
    {
        var ordered = _sections.OrderBy(s => s.Order).ToList();
        var idx = ordered.FindIndex(s => s.NativeKey == nativeKey && s.SectionType == "native");
        return idx <= 0;
    }

    private bool IsLastSection(string nativeKey)
    {
        var ordered = _sections.OrderBy(s => s.Order).ToList();
        var idx = ordered.FindIndex(s => s.NativeKey == nativeKey && s.SectionType == "native");
        return idx < 0 || idx == ordered.Count - 1;
    }

    private void LoadSections()
    {
        _pageDef = ReportPageCfg.GetPage("/audit");
        _sections = _pageDef != null
            ? _pageDef.Sections.OrderBy(s => s.Order).ToList()
            : AllNativeKeys.Select((k, i) => new ReportSection { NativeKey = k, Title = k, SectionType = "native", Order = i, Enabled = true }).ToList();
    }

    private void MoveSection(ReportSection section, int direction)
    {
        if (_pageDef == null) return;
        ReportPageCfg.MoveSection(_pageDef.Id, section.Id, direction);
        LoadSections();
        StateHasChanged();
    }

    private void DeleteSection(ReportSection section)
    {
        if (_pageDef == null) return;
        ReportPageCfg.DeleteSection(_pageDef.Id, section.Id);
        LoadSections();
        StateHasChanged();
    }

    private void ToggleSection(ReportSection section)
    {
        if (_pageDef == null) return;
        section.Enabled = !section.Enabled;
        ReportPageCfg.UpsertSection(_pageDef.Id, section);
        LoadSections();
        StateHasChanged();
    }

    private void HandleSectionSaved(ReportSection section)
    {
        if (_pageDef == null) return;
        ReportPageCfg.UpsertSection(_pageDef.Id, section);
        LoadSections();
        _editingSection = null;
        StateHasChanged();
    }

    private void HandleSectionAdded(ReportSection section)
    {
        if (_pageDef == null) return;
        section.Order = _sections.Count;
        ReportPageCfg.UpsertSection(_pageDef.Id, section);
        LoadSections();
        _showAddSection = false;
        StateHasChanged();
    }

    private void ResetSections()
    {
        // Remove all sections and let the service regenerate defaults
        if (_pageDef == null) return;
        foreach (var s in _sections.ToList())
            ReportPageCfg.DeleteSection(_pageDef.Id, s.Id);
        // Re-seed native keys
        int i = 0;
        foreach (var key in AllNativeKeys)
            ReportPageCfg.UpsertSection(_pageDef.Id, new ReportSection
            {
                Id = Guid.NewGuid().ToString("N")[..8],
                Title = key, NativeKey = key, SectionType = "native", Enabled = true, Order = i++
            });
        LoadSections();
        StateHasChanged();
    }

    private List<ServerConnection> Connections => ConnectionManager.GetConnections();
    private List<ServerConnection> EnabledConnections => ConnectionManager.GetEnabledConnections();
    private int EnabledChecksCount => CheckRepo.GetEnabledChecks().Count;
    private int EnabledServersCount => EnabledConnections.SelectMany(c => c.GetServerList()).Count();

    /// <summary>Id/Label pairs fed to ServerSelector in id-keyed mode.
    /// Shows all connections (including disabled) — same set as the old &lt;select&gt;.</summary>
    private IReadOnlyList<(string Id, string Label)> ConnectionItems =>
        Connections
            .Select(conn =>
            {
                var label = conn.ServerNames + " (" + conn.AuthenticationDisplay + ")"
                    + (conn.Environment != null ? $" [{conn.Environment}]" : "")
                    + (!conn.IsEnabled ? " [DISABLED]" : "");
                return (conn.Id, label);
            })
            .ToList();

    /// <summary>Called by ServerSelector when the user picks a chip or "All servers".
    /// Maps to the same RunAllServers / SelectedConnectionId / OnServerSelected pattern.</summary>
    private void OnConnectionSelected(string? id)
    {
        if (string.IsNullOrEmpty(id))
        {
            State.RunAllServers        = true;
            State.SelectedConnectionId = string.Empty;
        }
        else
        {
            State.RunAllServers        = false;
            State.SelectedConnectionId = id;
        }
        OnServerSelected();
    }

    // SKIP semantics: CheckExecutionService maps permission-denied SqlExceptions to
    // Passed=true with Message starting "SKIP — ...". The verdict-tier model also
    // emits "SKIP" verdicts from the check SQL itself. Both flow through this helper.
    private static bool IsSkipped(SQLTriage.Data.Models.CheckResult r) =>
        !string.IsNullOrEmpty(r.Message)
        && r.Message.TrimStart().StartsWith("SKIP", StringComparison.OrdinalIgnoreCase);

    private int PassedCount  => State.Results.Count(r => r.Passed && !IsSkipped(r) && string.IsNullOrEmpty(r.ErrorMessage));
    private int FailedCount  => State.Results.Count(r => !r.Passed && string.IsNullOrEmpty(r.ErrorMessage));
    private int ErrorCount   => State.Results.Count(r => !string.IsNullOrEmpty(r.ErrorMessage));
    private int SkippedCount => State.Results.Count(IsSkipped);

    private List<string> ServersInResults =>
        State.Results.Select(r => r.InstanceName).Distinct().OrderBy(s => s).ToList();

    private IEnumerable<CheckResult> FilteredResults
    {
        get
        {
            var filtered = State.Results.AsEnumerable();

            filtered = State.SelectedFilter switch
            {
                "passed"  => filtered.Where(r => r.Passed && !IsSkipped(r) && string.IsNullOrEmpty(r.ErrorMessage)),
                "failed"  => filtered.Where(r => !r.Passed && string.IsNullOrEmpty(r.ErrorMessage)),
                "errors"  => filtered.Where(r => !string.IsNullOrEmpty(r.ErrorMessage)),
                "skipped" => filtered.Where(IsSkipped),
                _        => filtered
            };

            if (!string.IsNullOrEmpty(State.SelectedCategory))
                filtered = filtered.Where(r => r.Category.Equals(State.SelectedCategory, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrEmpty(State.SelectedServer))
                filtered = filtered.Where(r => r.InstanceName.Equals(State.SelectedServer, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrEmpty(State.SelectedSeverity))
                filtered = filtered.Where(r => r.Severity.Equals(State.SelectedSeverity, StringComparison.OrdinalIgnoreCase));

            return filtered;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        LoadSections();
        ShowDiagnosticPane = UserSettings.GetShowDiagnosticPane();
        await CheckRepo.LoadChecksAsync();

        // Re-attach to state change notifications each time the page mounts
        State.StateChanged += OnStateChanged;

        // Keyboard shortcuts
        ShortcutSvc.OnRunRequested       += OnShortcutRun;
        ShortcutSvc.OnExportPdfRequested += OnShortcutPdf;

        // Ensure categories are populated (may have been loaded on a prior visit)
        if (State.Categories.Count == 0)
            State.Categories = CheckRepo.GetEnabledChecks()
                .Select(c => c.Category).Distinct().OrderBy(c => c).ToList();

        await MergeSpBlitzFindings();
        ScanForBlitzOutputFiles();

        _initialized = true;
    }

    // ── sp_BLITZ Free-tier prompt + merge ────────────────────────────────────
    // On Free tier the app supports importing sp_BLITZ CSV output. If the user
    // has no imported data yet, prompt them toward the import flow. Once imported,
    // findings are adapted to CheckResult rows and merged into the results grid
    // alongside live checks, distinguished by the "sp_BLITZ" category badge.

    private bool _hasSpBlitzData;
    private bool _showSpBlitzImport;

    // Multi-server run mode (All scope). Mirrors Raw Diagnostics.
    private bool _parallelMode;
    private int _parallelDelaySeconds = 2;

    private bool ShowSpBlitzPrompt =>
        Bundle.Tier == Tier.Free
        && Bundle.Features.SpBlitzImport
        && !_hasSpBlitzData;

    /// <summary>
    /// Loads all imported sp_BLITZ findings, adapts them to CheckResult rows, and
    /// merges any not already present (dedup by CheckId) into State.Results so they
    /// render in the shared grid. Registers the sp_BLITZ category for the filter.
    /// </summary>
    private async Task MergeSpBlitzFindings()
    {
        if (!Bundle.Features.SpBlitzImport) return;

        var findings = await BlitzCache.LoadAllRecentAsync(2000);
        _hasSpBlitzData = findings.Count > 0;
        if (findings.Count == 0) return;

        var existingIds = new HashSet<string>(State.Results.Select(r => r.CheckId), StringComparer.Ordinal);
        var adapted = BlitzFindingToCheckResultAdapter.AdaptAll(findings)
            .Where(r => existingIds.Add(r.CheckId))
            .ToList();

        if (adapted.Count == 0) return;

        State.Results.AddRange(adapted);

        if (!State.Categories.Contains(BlitzFindingToCheckResultAdapter.BlitzCategory))
        {
            State.Categories.Add(BlitzFindingToCheckResultAdapter.BlitzCategory);
            State.Categories = State.Categories.OrderBy(c => c).ToList();
        }
    }

    private void ToggleSpBlitzImport() => _showSpBlitzImport = !_showSpBlitzImport;

    private async Task OnSpBlitzImported()
    {
        await MergeSpBlitzFindings();
        StateHasChanged();
    }

    // ── Auto-detect sp_Blitz files in the output folder ───────────────────────
    // Same output-folder source the Compliance Roadmap scans. Lets the user import
    // findings without a manual drag-drop. Manual import stays available too.
    private IReadOnlyList<AuditOutputFile> _detectedBlitzFiles = Array.Empty<AuditOutputFile>();
    private bool _importingDetected;

    private string DetectedBlitzTooltip =>
        "Auto-detected in the output folder: " +
        string.Join(", ", _detectedBlitzFiles.Select(f => f.ServerName));

    private void ScanForBlitzOutputFiles()
    {
        if (!Bundle.Features.SpBlitzImport) return;
        try { _detectedBlitzFiles = OutputScanner.ScanSpBlitzFiles(); }
        catch { _detectedBlitzFiles = Array.Empty<AuditOutputFile>(); }
    }

    private async Task ImportDetectedBlitzFiles()
    {
        if (_detectedBlitzFiles.Count == 0 || _importingDetected) return;
        _importingDetected = true;
        StateHasChanged();
        try
        {
            int imported = 0, fileCount = 0;
            foreach (var f in _detectedBlitzFiles)
            {
                try
                {
                    using var fs = File.OpenRead(f.FilePath);
                    var findings = SpBlitzCsvParser.Parse(
                        fs, f.ServerName, DateTime.UtcNow, Guid.NewGuid(), out _);
                    if (findings.Count > 0)
                    {
                        await BlitzCache.SaveAsync(findings);
                        imported += findings.Count;
                        fileCount++;
                    }
                }
                catch (Exception ex)
                {
                    Toast.ShowError($"sp_Blitz import failed for {f.ServerName}: {ex.Message}");
                }
            }

            await MergeSpBlitzFindings();
            // Re-scan so the prompt reflects the now-imported state.
            ScanForBlitzOutputFiles();
            if (imported > 0)
                Toast.ShowInfo($"Imported {imported} sp_Blitz finding(s) from {fileCount} output file(s).");
        }
        finally
        {
            _importingDetected = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _disposed = true;
        State.StateChanged -= OnStateChanged;
        ShortcutSvc.OnRunRequested       -= OnShortcutRun;
        ShortcutSvc.OnExportPdfRequested -= OnShortcutPdf;
    }

