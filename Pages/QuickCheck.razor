            var orientation = settings.LandscapeOrientation
                ? Microsoft.Web.WebView2.Core.CoreWebView2PrintOrientation.Landscape
                : Microsoft.Web.WebView2.Core.CoreWebView2PrintOrientation.Portrait;
            var qcEnv2 = ConnectionManager.GetConnection(State.SelectedConnectionId)?.Environment;
            var qcWatermark2 = !settings.SuppressWatermark &&
                ServerEnvironment.RequiresWatermark(new[] { qcEnv2 });
