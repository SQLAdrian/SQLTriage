<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/environment"
@using SQLTriage.Components.Shared
<PageTitle>SQLTriage - Environment</PageTitle>
@inject ServerConnectionManager ConnectionManager
@inject IJSRuntime JS
@inject AuditLogService AuditLog
@inject SQLTriage.Data.Services.Discovery.EnvironmentDiscoveryService DiscoveryService
@using SQLTriage.Data.Services.Discovery
@using Microsoft.Data.SqlClient
@using System.Data
@using System.Linq
@using System.Threading
@using SQLTriage.Data
@using SQLTriage.Data.Models
@implements IDisposable

<div class="env-page">

    <!-- ── Toolbar ─────────────────────────────────────────────────────── -->
    <div class="env-toolbar card-glass" style="margin: 0; border-radius: 0; border-left: none; border-right: none; padding: 12px 16px;">
        <div class="env-toolbar-left">
            <i class="fa-solid fa-network-wired" style="color:var(--accent);font-size:18px;"></i>
            <span style="font-size:15px;font-weight:600;color:var(--text-primary);">Operations Hub</span>
            @if (_serverResults.Count > 0 && !_isScanning)
            {
                <span style="font-size:11px;color:var(--text-muted);margin-left:6px;">
                    @_serverResults.Count server(s) · @(_serverResults.Sum(s => s.HostCount)) hosts
                </span>
            }
        </div>
        <div class="env-toolbar-right">
            <button class="btn btn-secondary"
                    @onclick="OpenDigDeeperConsent"
                    disabled="@(_discovering || _isScanning)"
                    title="Actively map the whole environment (replication / mirroring / AG / linked-server chain). Requires consent each run.">
                <i class="fa-solid fa-sitemap"></i><span> Dig deeper</span>
            </button>
            <ServerSelector Items="EnvServerItems"
                            SelectedId="@(_runAllServers ? null : _selectedConnectionId)"
                            SelectedIdChanged="OnEnvServerChanged"
                            AllowAllScope="true" />
            <button class="btn btn-primary" @onclick="ScanEnvironment"
                    disabled="@(_isScanning || (!_runAllServers && string.IsNullOrEmpty(_selectedConnectionId)))">
                @if (_isScanning)
                {
                    <i class="fa-solid fa-spinner fa-spin"></i><span> Scanning...</span>
                }
                else
                {
                    <i class="fa-solid fa-radar"></i><span> Scan</span>
                }
            </button>
            @if (_serverResults.Count > 0)
            {
                <button class="btn btn-secondary" @onclick="ClearResults">Clear</button>
                <button class="btn btn-secondary" @onclick="ExportPngAsync" title="Download topology as PNG">
                    <i class="fa-solid fa-image"></i> Export PNG
                </button>
            }
        </div>
    </div>

    @* ── Dig Deeper consent modal (required every run; consent is NOT persisted) ── *@
    @if (_showConsent)
    {
        <div style="position:fixed;inset:0;background:rgba(0,0,0,.55);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="card-glass" style="max-width:560px;padding:22px;border-radius:10px;">
                <h3 style="margin-top:0;"><i class="fa-solid fa-sitemap" style="color:var(--accent);"></i> Map the environment</h3>
                <p>SQLTriage will attempt to discover and map your SQL Server environment, starting from
                   <strong>@_digDeeperSeedLabel</strong>. With your approval it will:</p>
                <ul style="line-height:1.6;font-size:13px;">
                    <li>Query <strong>Active Directory</strong> for registered SQL Server instances (SPNs). <strong>No port scanning.</strong></li>
                    @if (_seedAuthIsWindows)
                    {
                        <li>Connect <strong>read-only</strong> to each discovered server under your Windows credentials.</li>
                    }
                    else
                    {
                        <li>Connect <strong>read-only</strong> to each discovered server using the <strong>stored SQL login</strong> of this connection —
                            <span style="color:#f59e0b;">those credentials will be presented to every server found.</span></li>
                    }
                    <li>Read server-to-server topology — replication, Always On AG, mirroring, log shipping, linked servers.</li>
                    <li>Count currently-connected clients per server (aggregate only).</li>
                </ul>
                @if (!_seedAuthIsWindows)
                {
                    <p style="color:#f59e0b;font-size:12px;"><i class="fa-solid fa-triangle-exclamation"></i>
                        Consider using a Windows-authenticated connection as the seed so no SQL login is sent to unknown servers.</p>
                }
                <p style="color:var(--text-muted);font-size:12px;">Read-only and cancellable. <strong>Nothing is stored</strong>
                   unless you choose to add discovered servers afterwards. This approval is required every run.</p>
                <label style="display:block;font-size:13px;margin:8px 0;">
                    <input type="checkbox" @bind="_useAdInRun" /> Use Active Directory to find servers (uncheck to crawl only from the seed server)
                </label>
                <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:14px;">
                    <button class="btn btn-secondary" @onclick="CancelConsent">Cancel</button>
                    <button class="btn btn-primary" @onclick="StartDiscovery"><i class="fa-solid fa-play"></i> Map my environment</button>
                </div>
            </div>
        </div>
    }

    @if (_discovering)
    {
        <div class="card-glass" style="display:flex;align-items:center;gap:10px;margin:0 10px 10px;padding:8px 12px;border-radius:8px;">
            <i class="fa-solid fa-spinner fa-spin" style="color:var(--accent);"></i>
            <span style="font-size:13px;">@_discoveryProgress</span>
            <button class="btn btn-secondary" style="margin-left:auto;" @onclick="CancelDiscovery">Cancel</button>
        </div>
    }

    @if (!string.IsNullOrEmpty(_truncationNote))
    {
        <div class="env-alert-error" style="background:rgba(224,86,74,.12);">
            <i class="fa-solid fa-triangle-exclamation"></i> @_truncationNote
        </div>
    }

    @if (!_discovering && _discoveredNotInCatalogue.Count > 0)
    {
        <div class="card-glass" style="margin:0 10px 10px;padding:10px 12px;border-radius:8px;display:flex;align-items:center;gap:8px;">
            <i class="fa-solid fa-database" style="color:var(--accent);"></i>
            <strong style="font-size:13px;">@_discoveredNotInCatalogue.Count discovered server(s) not in your catalogue</strong>
            @if (_addedToCatalogue)
            {
                <span style="color:var(--accent);font-size:12px;margin-left:auto;">Added — they will appear in your server list.</span>
            }
            else
            {
                <button class="btn btn-primary" style="margin-left:auto;" @onclick="AddDiscoveredToCatalogue">
                    <i class="fa-solid fa-plus"></i> Add all to catalogue
                </button>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="env-alert-error">
            <i class="fa-solid fa-circle-exclamation"></i> @_errorMessage
        </div>
    }

    @if (_serverResults.Count == 0 && !_isScanning)
    {
        <div class="env-empty">
            <i class="fa-solid fa-network-wired"></i>
            <p>Select server(s) and click <strong>Scan</strong> to visualize your environment.</p>
        </div>
    }

    @if (_serverResults.Count > 0 || _isScanning)
    {
        <!-- ── Main topology area ──────────────────────────────────────── -->
        <div class="env-lower" style="flex:1;min-height:0;">

            <!-- Force-directed topology canvas -->
            <div class="env-topo-strip" style="flex:1;min-width:0;">
                <div id="env-topo-canvas" class="env-topo-canvas">
                    @if (_isScanning)
                    {
                        <LoadingSpinner Message="@($"Scanning {_scanProgress}…")" />
                    }
                </div>
            </div>

            <!-- Host detail panel (slides in on node click) -->
            @if (_selectedHost != null)
            {
                <div class="env-host-detail">
                    <div class="env-host-detail-header">
                        <i class="fa-solid fa-desktop"></i>
                        <strong>@_selectedHost.Hostname</strong>
                        <span style="font-size:10px;color:var(--text-muted);margin-left:4px;">via @_selectedHostServer</span>
                        <button class="env-detail-close" @onclick="() => _selectedHost = null"><i class="fa-solid fa-xmark"></i></button>
                    </div>
                    <div class="env-detail-badges">
                        <span class="env-badge"><i class="fa-solid fa-plug"></i> @_selectedHost.ConnectionCount conn</span>
                        <span class="env-badge"><i class="fa-solid fa-cube"></i> @_selectedHost.UniqueApps apps</span>
                        <span class="env-badge"><i class="fa-solid fa-user"></i> @_selectedHost.UniqueUsers users</span>
                        <span class="env-badge"><i class="fa-solid fa-database"></i> @_selectedHost.UniqueDbs DBs</span>
                    </div>
                    <div class="env-host-detail-table-wrap">
                        <table class="env-detail-table">
                            <thead>
                                <tr>
                                    <th>Application</th>
                                    <th>User</th>
                                    <th>Database</th>
                                    <th>IP</th>
                                    <th>Driver</th>
                                    <th>Protocol</th>
                                    <th>Auth</th>
                                    <th>Encrypt</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in _selectedHost.Connections)
                                {
                                    <tr>
                                        <td title="@c.App">@c.App</td>
                                        <td title="@c.User">@c.User</td>
                                        <td title="@c.Database">@c.Database</td>
                                        <td>@c.IP</td>
                                        <td>@c.DriverVersion</td>
                                        <td>@c.ProtocolVersion</td>
                                        <td>@c.AuthScheme</td>
                                        <td>@c.EncryptOption</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div style="margin-top: 16px;">
                        <h4 style="font-size: 12px; color: var(--text-muted); margin-bottom: 8px;">Real-Time Telemetry</h4>
                        <div style="display: flex; gap: 10px;">
                            <div class="card-glass" style="flex: 1; padding: 10px; border-radius: 6px;">
                                <div style="font-size: 10px; color: var(--text-muted); margin-bottom: -10px;">CPU Load</div>
                                <ApexChart TItem="TelemetryPoint" Height="60" Options="@_sparklineOptions">
                                    <ApexPointSeries TItem="TelemetryPoint" Items="@_cpuTelemetry" Name="CPU" SeriesType="SeriesType.Area" XValue="@(e => "T")" YValue="@(e => e.Value)" Color="#00b4d8" />
                                </ApexChart>
                            </div>
                            <div class="card-glass" style="flex: 1; padding: 10px; border-radius: 6px;">
                                <div style="font-size: 10px; color: var(--text-muted); margin-bottom: -10px;">Network I/O</div>
                                <ApexChart TItem="TelemetryPoint" Height="60" Options="@_sparklineOptions">
                                    <ApexPointSeries TItem="TelemetryPoint" Items="@_netTelemetry" Name="Net" SeriesType="SeriesType.Area" XValue="@(e => "T")" YValue="@(e => e.Value)" Color="#e0564a" />
                                </ApexChart>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    // ── State ────────────────────────────────────────────────────────────
    private List<ServerConnection> _connections = new();
    private List<ServerConnection> _enabledConnections = new();
    private bool _runAllServers = true;
    private string _selectedConnectionId = "";

    // Shared ServerSelector (id mode, composite "connId|server" + All-scope) adapter.
    private IReadOnlyList<(string Id, string Label)> EnvServerItems => _enabledConnections
        .SelectMany(c => c.GetServerList().Select(s => (c.Id + "|" + s, s)))
        .ToList();

    private void OnEnvServerChanged(string? id)
    {
        if (string.IsNullOrEmpty(id)) { _runAllServers = true; }
        else { _runAllServers = false; _selectedConnectionId = id; }
    }
    private bool _isScanning = false;
    private string? _errorMessage;
    private string _scanProgress = "";

    private List<ServerEnvironmentResult> _serverResults = new();
    private List<CrossLink> _crossLinks = new();

    private HostNode? _selectedHost;
    private string _selectedHostServer = "";

    private DotNetObjectReference<EnvironmentView>? _dotNetRef;
    private bool _disposed = false;
    private bool _needsTopologyRender = false;
    private System.Threading.Timer? _progressTimer;

    protected override void OnInitialized()
    {
        _connections = ConnectionManager.GetConnections();
        _enabledConnections = ConnectionManager.GetEnabledConnections();
        _sparklineOptions.Chart = new Chart { Sparkline = new ChartSparkline { Enabled = true }, Background = "transparent" };
        _sparklineOptions.Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 };
        _sparklineOptions.Tooltip = new Tooltip { Enabled = false };
        _sparklineOptions.Xaxis = new XAxis { Labels = new XAxisLabels { Show = false }, Tooltip = new XAxisTooltip { Enabled = false }, AxisBorder = new AxisBorder { Show = false }, AxisTicks = new AxisTicks { Show = false } };
        _sparklineOptions.Yaxis = new List<YAxis> { new YAxis { Show = false, Min = 0, Max = 100 } };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            try
            {
                // Reuse the stored reference; a second Create() would leak (never disposed).
                await JS.InvokeVoidAsync("environmentView.setHostCallback", _dotNetRef);
            }
            catch { /* JS not ready on first navigation — harmless */ }
        }

        if (_needsTopologyRender)
        {
            _needsTopologyRender = false;
            await RenderTopology();
        }
    }

    [Microsoft.JSInterop.JSInvokable]
    public void OnHostNodeClicked(string hostname)
    {
        if (_disposed) return;
        if (string.IsNullOrEmpty(hostname))
        {
            _selectedHost = null;
            _selectedHostServer = "";
            _ = InvokeAsync(StateHasChanged);
            return;
        }
        foreach (var sr in _serverResults)
        {
            var host = sr.Hosts?.FirstOrDefault(
                h => string.Equals(h.Hostname, hostname, StringComparison.OrdinalIgnoreCase));
            if (host != null)
            {
                _selectedHost = host;
                _selectedHostServer = sr.ServerName;
                GenerateMockTelemetry();
                break;
            }
        }
        _ = InvokeAsync(StateHasChanged);
    }

    private ApexChartOptions<TelemetryPoint> _sparklineOptions = new();
    private List<TelemetryPoint> _cpuTelemetry = new();
    private List<TelemetryPoint> _netTelemetry = new();

    private void GenerateMockTelemetry()
    {
        var rnd = new Random();
        _cpuTelemetry = Enumerable.Range(0, 20).Select(_ => new TelemetryPoint { Value = rnd.Next(10, 90) }).ToList();
        _netTelemetry = Enumerable.Range(0, 20).Select(_ => new TelemetryPoint { Value = rnd.Next(20, 80) }).ToList();
    }

    public class TelemetryPoint { public int Value { get; set; } }

    private async Task ScanEnvironment()
    {
        _isScanning = true;
        _errorMessage = null;
        _serverResults.Clear();
        _crossLinks.Clear();
        _topoMeta.Clear();
        _selectedHost = null;
        _selectedHostServer = "";
        _needsTopologyRender = false;
        StateHasChanged();
        try { await JS.InvokeVoidAsync("environmentView.resetLayout", "env-topo-canvas"); } catch { }

        try
        {
            var targets = new List<(ServerConnection conn, string serverName)>();
            if (_runAllServers)
            {
                foreach (var conn in _enabledConnections)
                    foreach (var s in conn.GetServerList())
                        targets.Add((conn, s));
            }
            else
            {
                var parts = _selectedConnectionId.Split('|', 2);
                var conn  = _connections.FirstOrDefault(c => c.Id == parts[0]);
                if (conn != null)
                {
                    var srv = parts.Length > 1 ? parts[1] : conn.GetServerList().FirstOrDefault();
                    if (!string.IsNullOrEmpty(srv))
                        targets.Add((conn, srv));
                }
            }

            if (targets.Count == 0) { _errorMessage = "No servers selected."; return; }

            // Start progress timer for UI updates
            _progressTimer = new System.Threading.Timer(_ => InvokeAsync(() => StateHasChanged()), null, 0, 500);

            // Scan with progress feedback
            var results = new List<ServerEnvironmentResult>();
            for (int i = 0; i < targets.Count; i++)
            {
                var t = targets[i];
                _scanProgress = $"{t.serverName} ({i+1}/{targets.Count})";
                var r = await ScanServerAsync(t.conn, t.serverName);
                if (r != null) results.Add(r);
            }

            _serverResults = MergeByPhysicalHost(results);

            if (_serverResults.Count == 0) { _errorMessage = "No results returned."; return; }

            BuildCrossLinks();

            // Schedule topology render after next render cycle
            _needsTopologyRender = true;
        }
        catch (Exception ex) { _errorMessage = $"Scan failed: {ex.Message}"; }
        finally 
        { 
            _progressTimer?.Dispose(); 
            _progressTimer = null; 
            _isScanning = false; 
            _scanProgress = ""; 
            StateHasChanged(); 
        }
    }

    private async Task RenderTopology()
    {
        await Task.Delay(50); // let DOM render canvas div

        var json = System.Text.Json.JsonSerializer.Serialize(new
        {
            servers = _serverResults.Select(sr =>
            {
                _topoMeta.TryGetValue(sr.ServerName, out var meta);
                return new
                {
                    name   = sr.ServerName,
                    error  = sr.Error,
                    // Dig Deeper metadata (null for plain Scan results)
                    discovered  = meta != null,
                    fromAd      = meta?.FromActiveDirectory ?? false,
                    inCatalogue = meta?.InCatalogue ?? true,
                    counts = new
                    {
                        hosts = sr.HostCount,
                        apps  = sr.AppCount,
                        users = sr.UserCount,
                        dbs   = sr.DbCount,
                        ips   = sr.IpCount,
                        auth  = sr.AuthCount
                    },
                    hosts = (sr.Hosts ?? new()).Select(h => new
                    {
                        hostname        = h.Hostname,
                        connectionCount = h.ConnectionCount,
                        uniqueApps      = h.UniqueApps,
                        uniqueUsers     = h.UniqueUsers,
                        uniqueDbs       = h.UniqueDbs,
                        topApp          = TopAppOf(h),
                        subnet          = SubnetOf(h)
                    })
                };
            }),
            crossLinks = _crossLinks.Select(l => new
            {
                fromServer      = l.FromServer,
                toServer        = l.ToServer,
                connectionCount = l.ConnectionCount,
                edgeKind        = l.EdgeKind,
                detail          = string.IsNullOrEmpty(l.Detail) ? l.ViaHost : l.Detail
            })
        });

        try
        {
            await JS.InvokeVoidAsync("environmentView.renderTopology", "env-topo-canvas", json);
        }
        catch { }
    }

    // Most common application across a host's connections — drives client clustering by app.
    private static string TopAppOf(HostNode h) =>
        h.Connections
            .Where(c => !string.IsNullOrEmpty(c.App))
            .GroupBy(c => c.App, StringComparer.OrdinalIgnoreCase)
            .OrderByDescending(g => g.Count())
            .Select(g => g.Key)
            .FirstOrDefault() ?? "";

    // /24 of the host's most common IPv4 — drives client clustering by subnet.
    private static string SubnetOf(HostNode h)
    {
        var ip = h.Connections
            .Where(c => !string.IsNullOrEmpty(c.IP))
            .GroupBy(c => c.IP)
            .OrderByDescending(g => g.Count())
            .Select(g => g.Key)
            .FirstOrDefault();
        if (string.IsNullOrEmpty(ip)) return "";
        var parts = ip.Split('.');
        return parts.Length == 4 ? $"{parts[0]}.{parts[1]}.{parts[2]}.x" : "";
    }

    private void ClearResults()
    {
        _serverResults.Clear();
        _crossLinks.Clear();
        _selectedHost = null;
        _selectedHostServer = "";
        _errorMessage = null;
        _truncationNote = null;
        _discoveredNotInCatalogue.Clear();
        _topoMeta.Clear();
        _addedToCatalogue = false;
        try { _ = JS.InvokeVoidAsync("environmentView.resetLayout", "env-topo-canvas"); } catch { }
    }

    // ── Dig Deeper (environment topology discovery) — ephemeral, consent-gated, read-only ──
    private bool _showConsent = false;
    private bool _useAdInRun = true;
    private bool _discovering = false;
    private string _discoveryProgress = "";
    private string? _truncationNote;
    private bool _addedToCatalogue = false;
    private CancellationTokenSource? _discoveryCts;
    private readonly Dictionary<string, ServerEnvironmentResult> _discoveredNodes = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, TopologyNode> _topoMeta = new(StringComparer.OrdinalIgnoreCase);
    private List<string> _discoveredNotInCatalogue = new();
    private string _digDeeperSeedLabel = "";
    private bool _seedAuthIsWindows = true;
    private (ServerConnection conn, string server)? _digDeeperSeed;
    private long _lastTopoRenderMs;   // throttle live re-renders so the canvas doesn't rebuild per probe

    private (ServerConnection conn, string server)? ResolveSeed()
    {
        if (!_runAllServers && !string.IsNullOrEmpty(_selectedConnectionId))
        {
            var parts = _selectedConnectionId.Split('|', 2);
            var c = _connections.FirstOrDefault(x => x.Id == parts[0]);
            if (c != null)
            {
                var s = parts.Length > 1 ? parts[1] : c.GetServerList().FirstOrDefault();
                if (!string.IsNullOrEmpty(s)) return (c, s!);
            }
        }
        foreach (var c in _enabledConnections)
        {
            var s = c.GetServerList().FirstOrDefault();
            if (!string.IsNullOrEmpty(s)) return (c, s!);
        }
        return null;
    }

    private void OpenDigDeeperConsent()
    {
        _digDeeperSeed = ResolveSeed();
        if (_digDeeperSeed == null) { _errorMessage = "Add or select a server to use as the discovery seed."; return; }
        _digDeeperSeedLabel = _digDeeperSeed.Value.server;
        _seedAuthIsWindows = _digDeeperSeed.Value.conn.EffectiveAuthType == AuthenticationTypes.Windows;
        _useAdInRun = true;
        _truncationNote = null;
        _showConsent = true;
    }

    private void CancelConsent() => _showConsent = false;
    private void CancelDiscovery() => _discoveryCts?.Cancel();

    private async Task StartDiscovery()
    {
        _showConsent = false;
        if (_digDeeperSeed == null) return;
        var seedConn = _digDeeperSeed.Value.conn;
        var seedServer = _digDeeperSeed.Value.server;

        _discovering = true;
        _errorMessage = null;
        _truncationNote = null;
        _addedToCatalogue = false;
        _serverResults.Clear();
        _crossLinks.Clear();
        _discoveredNodes.Clear();
        _topoMeta.Clear();
        _discoveredNotInCatalogue.Clear();
        _selectedHost = null;
        _selectedHostServer = "";
        _lastTopoRenderMs = 0;
        StateHasChanged();

        AuditLog.LogSecurityEvent(
            $"Dig Deeper discovery started (seed: {seedServer}, AD enumeration: {(_useAdInRun ? "on" : "off")}, auth: {seedConn.AuthenticationDisplay})",
            AuditSeverity.Info);
        try { await JS.InvokeVoidAsync("environmentView.resetLayout", "env-topo-canvas"); } catch { }
        _discoveryCts = new CancellationTokenSource();
        var catalogue = _connections.SelectMany(c => c.GetServerList()).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var options = new DiscoveryOptions { UseActiveDirectory = _useAdInRun };

        try
        {
            await DiscoveryService.DiscoverAsync(seedConn, seedServer, options, catalogue, OnTopologyDelta, _discoveryCts.Token);
        }
        catch (OperationCanceledException) { _discoveryProgress = "Discovery cancelled."; }
        catch (Exception ex) { _errorMessage = $"Discovery failed: {ex.Message}"; }
        finally
        {
            _discovering = false;
            _discoveryCts?.Dispose();
            _discoveryCts = null;
            StateHasChanged();
        }
    }

    private async Task OnTopologyDelta(TopologyDelta delta)
    {
        if (_disposed) return;

        // Deltas arrive on the crawl's background thread — do all state mutation on the sync context.
        await InvokeAsync(async () =>
        {
            if (delta.Node != null)
            {
                var n = delta.Node;
                if (!_discoveredNodes.TryGetValue(n.Server, out var ser))
                {
                    ser = new ServerEnvironmentResult { ServerName = n.Server };
                    _discoveredNodes[n.Server] = ser;
                }
                ser.Error = n.Reachable ? null : (n.Error ?? "unreachable");
                ser.HostCount = n.ClientCount;
                _topoMeta[n.Server] = n;
            }

            foreach (var e in delta.Edges)
            {
                if (!_discoveredNodes.ContainsKey(e.ToServer))
                    _discoveredNodes[e.ToServer] = new ServerEnvironmentResult { ServerName = e.ToServer };

                var kind = e.Kind.ToString();
                if (!_crossLinks.Any(l =>
                        string.Equals(l.FromServer, e.FromServer, StringComparison.OrdinalIgnoreCase) &&
                        string.Equals(l.ToServer, e.ToServer, StringComparison.OrdinalIgnoreCase) &&
                        l.EdgeKind == kind))
                {
                    _crossLinks.Add(new CrossLink
                    {
                        FromServer = e.FromServer, ToServer = e.ToServer,
                        ConnectionCount = 1, EdgeKind = kind, Detail = e.Detail ?? ""
                    });
                }
            }

            if (!string.IsNullOrEmpty(delta.Progress)) _discoveryProgress = delta.Progress;

            if (delta.Done)
            {
                _truncationNote = delta.TruncationNote;
                var catalogue = _connections.SelectMany(c => c.GetServerList())
                    .Select(ServerNames.Normalize)
                    .ToHashSet(StringComparer.Ordinal);
                _discoveredNotInCatalogue = _discoveredNodes.Keys
                    .Where(s => !catalogue.Contains(ServerNames.Normalize(s)))
                    .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)
                    .ToList();
                AuditLog.LogSecurityEvent(
                    $"Dig Deeper discovery finished: {_discoveredNodes.Count} server(s), {_crossLinks.Count} relationship(s), {_discoveredNotInCatalogue.Count} not in catalogue" +
                    (delta.TruncationNote != null ? $" — {delta.TruncationNote}" : ""),
                    AuditSeverity.Info);
            }

            _serverResults = _discoveredNodes.Values.OrderBy(r => r.ServerName, StringComparer.OrdinalIgnoreCase).ToList();

            StateHasChanged();

            // Rebuilding the canvas per probed server makes the graph jitter — throttle to ~1.5/s,
            // always rendering the final state.
            var now = Environment.TickCount64;
            if (delta.Done || now - _lastTopoRenderMs > 650)
            {
                _lastTopoRenderMs = now;
                await RenderTopology();
            }
        });
    }

    private void AddDiscoveredToCatalogue()
    {
        if (_discoveredNotInCatalogue.Count == 0) return;
        try
        {
            var conn = new ServerConnection
            {
                ServerNames = string.Join("\n", _discoveredNotInCatalogue),
                Database    = "master",
                Environment = "Discovered",
                IsEnabled   = true,
                Tags        = new List<string> { $"dig-deeper {DateTime.Now:yyyy-MM-dd HH:mm}" },
            };
            if (_digDeeperSeed?.conn is { } seed)
            {
                // Carry the full auth context — an auth type without its credentials can't connect.
                conn.AuthenticationType       = seed.AuthenticationType;
                conn.UseWindowsAuthentication = seed.UseWindowsAuthentication;
                conn.Username                 = seed.Username;
                conn.Password                 = seed.Password;   // already encrypted at rest
                conn.TrustServerCertificate   = seed.TrustServerCertificate;
                conn.ConnectionTimeout        = seed.ConnectionTimeout;
            }
            ConnectionManager.AddConnection(conn);
            _addedToCatalogue = true;
            _connections = ConnectionManager.GetConnections();
            _enabledConnections = ConnectionManager.GetEnabledConnections();
        }
        catch (Exception ex) { _errorMessage = $"Add to catalogue failed: {ex.Message}"; }
    }

    private async Task ExportPngAsync()
    {
        var fileName = $"topology-{DateTime.Now:yyyyMMdd}.png";
        try
        {
            var dataUrl = await JS.InvokeAsync<string>("environmentView.exportPng", "env-topo-canvas");
            if (string.IsNullOrEmpty(dataUrl) || !dataUrl.StartsWith("data:image/png;base64,"))
            {
                _errorMessage = "Export failed: topology canvas not found. Run a Scan first.";
                StateHasChanged();
                return;
            }
            var base64 = dataUrl.Substring("data:image/png;base64,".Length);
            await JS.InvokeVoidAsync("blazorDownloadFile", fileName, "image/png", base64);
            AuditLog.LogExportOperation("PNG", fileName, true);
        }
        catch (Exception ex)
        {
            AuditLog.LogExportOperation("PNG", fileName, false, ex.Message);
            _errorMessage = $"Export failed: {ex.Message}";
            StateHasChanged();
        }
    }

    // ── Physical host deduplication ──────────────────────────────────────
    // When two SQL instances share the same physical machine (e.g. MSI and MSI\NEW2022),
    // merge them into one result keyed on the machine name.
    private static List<ServerEnvironmentResult> MergeByPhysicalHost(List<ServerEnvironmentResult> results)
    {
        // Group by the machine name (everything before the first backslash)
        var groups = new Dictionary<string, List<ServerEnvironmentResult>>(StringComparer.OrdinalIgnoreCase);
        foreach (var r in results)
        {
            var machine = r.ServerName.Split('\\')[0];
            if (!groups.TryGetValue(machine, out var g)) groups[machine] = g = new();
            g.Add(r);
        }

        var merged = new List<ServerEnvironmentResult>();
        foreach (var (machine, group) in groups)
        {
            if (group.Count == 1) { merged.Add(group[0]); continue; }

            // Pick a display name: prefer the bare machine name entry if it exists,
            // otherwise use the first sorted entry.
            var primary = group.FirstOrDefault(r =>
                string.Equals(r.ServerName, machine, StringComparison.OrdinalIgnoreCase))
                ?? group.OrderBy(r => r.ServerName).First();

            // Collect all hosts from all instances, dedup by hostname,
            // merge connection details when the same host appears on multiple instances.
            var allHosts = group
                .Where(r => r.Error == null && r.Hosts != null)
                .SelectMany(r => r.Hosts!)
                .ToList();

            var mergedHosts = allHosts
                .GroupBy(h => h.Hostname, StringComparer.OrdinalIgnoreCase)
                .Select(hg => new HostNode
                {
                    Hostname        = hg.Key,
                    Connections     = hg.SelectMany(h => h.Connections).ToList(),
                    ConnectionCount = hg.Sum(h => h.ConnectionCount),
                    UniqueApps      = hg.SelectMany(h => h.Connections).Select(c => c.App)
                                       .Where(a => !string.IsNullOrEmpty(a)).Distinct(StringComparer.OrdinalIgnoreCase).Count(),
                    UniqueUsers     = hg.SelectMany(h => h.Connections).Select(c => c.User)
                                       .Where(u => !string.IsNullOrEmpty(u)).Distinct(StringComparer.OrdinalIgnoreCase).Count(),
                    UniqueDbs       = hg.SelectMany(h => h.Connections).Select(c => c.Database)
                                       .Where(d => !string.IsNullOrEmpty(d)).Distinct(StringComparer.OrdinalIgnoreCase).Count()
                })
                .OrderByDescending(h => h.ConnectionCount)
                .ToList();

            // Label with all instance names so the user knows which instances were merged
            var instanceNames = string.Join(" + ", group.Select(r => r.ServerName).OrderBy(n => n));

            merged.Add(new ServerEnvironmentResult
            {
                ServerName = instanceNames,
                Error      = group.All(r => r.Error != null)
                               ? string.Join("; ", group.Where(r => r.Error != null).Select(r => r.Error))
                               : null,
                Hosts      = mergedHosts,
                HostCount  = mergedHosts.Count,
                AppCount   = mergedHosts.SelectMany(h => h.Connections).Select(c => c.App)
                               .Where(a => !string.IsNullOrEmpty(a)).Distinct(StringComparer.OrdinalIgnoreCase).Count(),
                UserCount  = mergedHosts.SelectMany(h => h.Connections).Select(c => c.User)
                               .Where(u => !string.IsNullOrEmpty(u)).Distinct(StringComparer.OrdinalIgnoreCase).Count(),
                DbCount    = mergedHosts.SelectMany(h => h.Connections).Select(c => c.Database)
                               .Where(d => !string.IsNullOrEmpty(d)).Distinct(StringComparer.OrdinalIgnoreCase).Count(),
                IpCount    = mergedHosts.SelectMany(h => h.Connections).Select(c => c.IP)
                               .Where(ip => !string.IsNullOrEmpty(ip)).Distinct(StringComparer.OrdinalIgnoreCase).Count(),
                AuthCount  = mergedHosts.SelectMany(h => h.Connections).Select(c => c.AuthScheme)
                               .Where(a => !string.IsNullOrEmpty(a)).Distinct(StringComparer.OrdinalIgnoreCase).Count(),
                EncrCount  = mergedHosts.SelectMany(h => h.Connections).Select(c => c.EncryptOption)
                               .Where(e => !string.IsNullOrEmpty(e)).Distinct(StringComparer.OrdinalIgnoreCase).Count()
            });
        }

        return merged.OrderBy(r => r.ServerName).ToList();
    }

    // ── Cross-link helpers ───────────────────────────────────────────────
    private void BuildCrossLinks()
    {
        _crossLinks.Clear();
        var serverNames = _serverResults.Select(s => s.ServerName).ToHashSet(StringComparer.OrdinalIgnoreCase);

        foreach (var sr in _serverResults.Where(s => s.Error == null && s.Hosts != null))
        {
            foreach (var host in sr.Hosts!)
            {
                foreach (var other in serverNames)
                {
                    if (string.Equals(sr.ServerName, other, StringComparison.OrdinalIgnoreCase)) continue;
                    var machinePart = other.Split('\\')[0];
                    if (host.Hostname.StartsWith(machinePart, StringComparison.OrdinalIgnoreCase))
                    {
                        if (!_crossLinks.Any(l =>
                            string.Equals(l.FromServer, sr.ServerName, StringComparison.OrdinalIgnoreCase) &&
                            string.Equals(l.ToServer, other, StringComparison.OrdinalIgnoreCase)))
                        {
                            _crossLinks.Add(new CrossLink
                            {
                                FromServer      = sr.ServerName,
                                ToServer        = other,
                                ViaHost         = host.Hostname,
                                ConnectionCount = host.ConnectionCount
                            });
                        }
                    }
                }
            }
        }
    }

    // ── Data models ──────────────────────────────────────────────────────
    private class ServerEnvironmentResult
    {
        public string ServerName { get; set; } = "";
        public string? Error { get; set; }
        public int HostCount { get; set; }
        public int AppCount  { get; set; }
        public int UserCount { get; set; }
        public int DbCount   { get; set; }
        public int IpCount   { get; set; }
        public int AuthCount { get; set; }
        public int EncrCount { get; set; }
        public List<HostNode>? Hosts { get; set; }
    }

    private class HostNode
    {
        public string Hostname       { get; set; } = "";
        public int ConnectionCount   { get; set; }
        public int UniqueApps        { get; set; }
        public int UniqueUsers       { get; set; }
        public int UniqueDbs         { get; set; }
        public List<HostConnectionDetail> Connections { get; set; } = new();
    }

    private class HostConnectionDetail
    {
        public string App             { get; set; } = "";
        public string DriverVersion   { get; set; } = "";
        public string Database        { get; set; } = "";
        public string ProtocolVersion { get; set; } = "";
        public string User            { get; set; } = "";
        public int    NonEngineConnection { get; set; }
        public string IP              { get; set; } = "";
        public string AuthScheme      { get; set; } = "";
        public string EncryptOption   { get; set; } = "";
    }

    private class CrossLink
    {
        public string FromServer    { get; set; } = "";
        public string ToServer      { get; set; } = "";
        public string ViaHost       { get; set; } = "";
        public int    ConnectionCount { get; set; }
        public string EdgeKind      { get; set; } = "";   // Dig Deeper: replication/ag-replica/mirror-partner/linked-server/logship-*
        public string Detail        { get; set; } = "";   // Dig Deeper: AG name / publication / mirrored DB etc.
    }

    public void Dispose()
    {
        _disposed = true;
        try { _discoveryCts?.Cancel(); } catch { }
        _discoveryCts?.Dispose();
        _progressTimer?.Dispose();
        _dotNetRef?.Dispose();
        // Best-effort: clear the JS reference so click callbacks don't fire into a disposed component.
        // Fire-and-forget — Dispose() is synchronous.
        try { _ = JS.InvokeVoidAsync("environmentView.setHostCallback", (object?)null); } catch { }
    }

    // ── SQL query ────────────────────────────────────────────────────────
    private async Task<ServerEnvironmentResult?> ScanServerAsync(ServerConnection conn, string serverName)
    {
        try
        {
            var connString = conn.GetConnectionString(serverName, "master");
            using var sqlConn = new SqlConnection(connString);
            await sqlConn.OpenAsync();
            using var cmd = new SqlCommand(EnvironmentQuery, sqlConn) { CommandTimeout = 30 };
            using var reader = await cmd.ExecuteReaderAsync();
            using var dt = new DataTable();
            dt.Load(reader);

            if (dt.Rows.Count == 0) return null;

            var firstRow = dt.Rows[0];
            var result = new ServerEnvironmentResult
            {
                ServerName = firstRow["Server"]?.ToString() ?? serverName,
                HostCount  = Convert.ToInt32(firstRow["C_Hosts"]),
                AppCount   = Convert.ToInt32(firstRow["C_App"]),
                UserCount  = Convert.ToInt32(firstRow["C_Users"]),
                DbCount    = Convert.ToInt32(firstRow["C_DBs"]),
                IpCount    = Convert.ToInt32(firstRow["C_IPs"]),
                AuthCount  = Convert.ToInt32(firstRow["C_Auth"]),
                EncrCount  = Convert.ToInt32(firstRow["C_Encr"])
            };

            var hostGroups = new Dictionary<string, List<HostConnectionDetail>>(StringComparer.OrdinalIgnoreCase);
            foreach (DataRow row in dt.Rows)
            {
                var hostname = row["Hostname"]?.ToString() ?? "(unknown)";
                if (!hostGroups.ContainsKey(hostname)) hostGroups[hostname] = new();
                hostGroups[hostname].Add(new HostConnectionDetail
                {
                    App               = row["App"]?.ToString() ?? "",
                    DriverVersion     = row["DriverVersion"]?.ToString() ?? "",
                    Database          = row["Database"]?.ToString() ?? "",
                    ProtocolVersion   = row["ProtocolVersion"]?.ToString() ?? "",
                    User              = row["User"]?.ToString() ?? "",
                    NonEngineConnection = Convert.ToInt32(row["Non-engine connection"]),
                    IP                = row["IP"]?.ToString() ?? "",
                    AuthScheme        = row["auth_scheme"]?.ToString() ?? "",
                    EncryptOption     = row["encrypt_option"]?.ToString() ?? ""
                });
            }

            result.Hosts = hostGroups.Select(g => new HostNode
            {
                Hostname        = g.Key,
                Connections     = g.Value,
                ConnectionCount = g.Value.Count,
                UniqueApps      = g.Value.Select(c => c.App).Where(a => !string.IsNullOrEmpty(a)).Distinct().Count(),
                UniqueUsers     = g.Value.Select(c => c.User).Where(u => !string.IsNullOrEmpty(u)).Distinct().Count(),
                UniqueDbs       = g.Value.Select(c => c.Database).Where(d => !string.IsNullOrEmpty(d)).Distinct().Count()
            }).OrderByDescending(h => h.ConnectionCount).ToList();

            return result;
        }
        catch (Exception ex)
        {
            return new ServerEnvironmentResult { ServerName = serverName, Error = ex.Message };
        }
    }

    private const string EnvironmentQuery = @"
DECLARE @ThisServer [NVARCHAR] (500)
DECLARE @CharToCheck [NVARCHAR] (5)
SET @CharToCheck = CHAR(92)
  IF (select CHARINDEX(@CharToCheck,@@SERVERNAME)) > 0
    SELECT @ThisServer = @@SERVERNAME
  IF (select CHARINDEX(@CharToCheck,@@SERVERNAME)) = 0
    SELECT @ThisServer = CAST( Serverproperty( 'ComputerNamePhysicalNetBIOS' ) AS [NVARCHAR] (500))

SELECT
    [Server], Hostname
    , MAX(RANKHostname)        OVER (PARTITION BY [Server] ORDER BY [Server]) [C_Hosts]
    , MAX(RANKApp)             OVER (PARTITION BY [Server] ORDER BY [Server]) [C_App]
    , MAX([RANKUser])          OVER (PARTITION BY [Server] ORDER BY [Server]) [C_Users]
    , MAX([RANKDatabase])      OVER (PARTITION BY [Server] ORDER BY [Server]) [C_DBs]
    , MAX([RANKIP])            OVER (PARTITION BY [Server] ORDER BY [Server]) [C_IPs]
    , MAX(RANKauth_scheme)     OVER (PARTITION BY [Server] ORDER BY [Server]) [C_Auth]
    , MAX(RANKencrypt_option)  OVER (PARTITION BY [Server] ORDER BY [Server]) [C_Encr]
    , App, DriverVersion, [Database], ProtocolVersion, [User]
    , [Non-engine connection], [IP], auth_scheme, encrypt_option
FROM (
    SELECT DISTINCT @ThisServer [Server]
    , ISNULL(T.host_name,'') Hostname
    , REPLACE(ISNULL(CASE WHEN T.program_name LIKE 'Microsoft SQL Server Management Studio%' THEN 'Microsoft SQL Server Management Studio' ELSE T.program_name END,''),':','_') App
    , ISNULL(T.nt_user_name,'') [User]
    , ISNULL(DB_NAME(T.database_id),ISNULL(DB_NAME(R.database_id),'')) [Database]
    , client_net_address [IP], C.auth_scheme, C.encrypt_option
    , DENSE_RANK() OVER (PARTITION BY @ThisServer ORDER BY ISNULL(T.host_name,'')) RANKHostname
    , DENSE_RANK() OVER (PARTITION BY @ThisServer ORDER BY REPLACE(ISNULL(CASE WHEN T.program_name LIKE 'Microsoft SQL Server Management Studio%' THEN 'Microsoft SQL Server Management Studio' ELSE T.program_name END,''),':','_')) RANKApp
    , DENSE_RANK() OVER (PARTITION BY @ThisServer ORDER BY ISNULL(T.nt_user_name,'')) [RANKUser]
    , DENSE_RANK() OVER (PARTITION BY @ThisServer ORDER BY ISNULL(DB_NAME(T.database_id),ISNULL(DB_NAME(R.database_id),''))) [RANKDatabase]
    , DENSE_RANK() OVER (PARTITION BY @ThisServer ORDER BY client_net_address) [RANKIP]
    , DENSE_RANK() OVER (PARTITION BY @ThisServer ORDER BY C.auth_scheme) RANKauth_scheme
    , DENSE_RANK() OVER (PARTITION BY @ThisServer ORDER BY C.encrypt_option) RANKencrypt_option
    , ISNULL(CASE WHEN T.client_version < 3 THEN 'SQL 6' WHEN T.client_version = 3 THEN 'SQL 7' WHEN T.client_version = 4 THEN 'SQL 2000' WHEN T.client_version = 5 THEN 'SQL 2005' WHEN T.client_version = 6 THEN 'SQL 2008' WHEN T.client_version = 7 THEN 'SQL 2012+' ELSE 'SQL 2014+' END,'') DriverVersion
    , ISNULL(CASE SUBSTRING(CAST(C.protocol_version AS BINARY(4)),1,1) WHEN 0x04 THEN 'Pre-SQL7' WHEN 0x70 THEN 'SQL 7.0' WHEN 0x71 THEN 'SQL 2000' WHEN 0x72 THEN 'SQL 2005' WHEN 0x73 THEN 'SQL 2008' WHEN 0x74 THEN 'SQL 2012+' ELSE SUBSTRING(CAST(C.protocol_version AS BINARY(4)),1,1) END,'') ProtocolVersion
    , CASE WHEN [services].service_account IS NULL AND client_net_address = '<local machine>' THEN 1 ELSE 0 END [Non-engine connection]
    FROM [sys].dm_exec_sessions T WITH(NOLOCK)
    LEFT OUTER JOIN [sys].dm_exec_connections C WITH(NOLOCK) ON C.session_id = T.session_id
    LEFT OUTER JOIN [sys].dm_exec_requests R WITH(NOLOCK) ON R.session_id = T.session_id
    LEFT OUTER JOIN [sys].dm_server_services AS [services] WITH(NOLOCK) ON T.original_login_name = [services].service_account
    WHERE T.client_version > 0 AND [services].service_account IS NULL
) C1";
}
