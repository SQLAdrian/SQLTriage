    private void LoadConnections()
    {
        _connections = ConnectionManager.GetConnections();

        if (SelectedConnection == null && _connections.Count > 0)
        {
            SelectedConnection = _connections.First();
            if (SelectedConnection.SuccessfulServers.Count > 0)
            {
                SelectedServer = SelectedConnection.SuccessfulServers.First();
            }
        }

        LoadScripts();
    }

    private void LoadScripts()
    {
        try
        {
            _scripts = ScriptRunner.LoadScriptConfigurations();
            _selectedScriptIds = new HashSet<string>(_scripts.Where(s => s.Enabled).Select(s => s.Id));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading script configurations");
        }
        _isLoading = false;
    }

    private void SelectServer(ServerConnection connection, string server)
    {
        SelectedConnection = connection;
        SelectedServer = server;
        AuditState.ClearExecutionResults();
        SaveState();
    }

    // ── Shared ServerSelector (id-mode) adapter ───────────────────────────────
    // Composite Id "{connId}|{server}" so the (connection, server) pair that
    // SelectServer needs is recoverable from a single string.
    private IReadOnlyList<(string Id, string Label)> FaServerItems
        => AllSuccessfulServers
            .Select(x => (x.Connection.Id + "|" + x.ServerName, x.ServerName))
            .ToList();

    private string? FaSelectedServerId
        => (SelectedConnection != null && SelectedServer != null)
            ? SelectedConnection.Id + "|" + SelectedServer
            : null;   // null == "All servers" scope (AllowAllScope contract)

    // True when the picker is on "All servers" scope (no single target chosen) and
    // there is at least one connected server to run against. Drives the
    // scripts/progress panel render gate so the panel (and its live Elapsed clock)
    // shows for All-scope runs, not just single-server selections.
    private bool _allScopeActive
        => FaSelectedServerId == null && AllSuccessfulServers.Count > 0;

    // The panel renders for a concrete single-server selection OR All scope.
    private bool _scriptsPanelVisible
        => (SelectedConnection != null && SelectedServer != null) || _allScopeActive;

    private void OnFaServerSelectorChanged(string? id)
    {
        if (string.IsNullOrEmpty(id))
        {
            // All-servers scope: clear the single-target selection.
            SelectedConnection = null;
            SelectedServer = null;
            AuditState.ClearExecutionResults();
            SaveState();
            return;
        }
        var sep = id.IndexOf('|');
        if (sep < 0) return;
        var connId = id.Substring(0, sep);
        var server = id.Substring(sep + 1);
        var match = AllSuccessfulServers
            .FirstOrDefault(x => x.Connection.Id == connId && x.ServerName == server);
        if (match.Connection != null)
            SelectServer(match.Connection, match.ServerName);
    }

    private void ToggleScriptSelection(string scriptId)
    {
        if (!_selectedScriptIds.Remove(scriptId))
            _selectedScriptIds.Add(scriptId);
    }

    private void ToggleSelectAll()
    {
        if (_selectedScriptIds.Count == _scripts.Count)
            _selectedScriptIds.Clear();
        else
            _selectedScriptIds = new HashSet<string>(_scripts.Select(s => s.Id));
    }

    private List<ScriptConfiguration> GetSelectedScripts() =>
        _scripts.Where(s => _selectedScriptIds.Contains(s.Id)).OrderBy(s => s.ExecutionOrder).ToList();

    private async Task RunSelectedScripts()
    {
        if (SelectedServer == null || SelectedConnection == null) return;
        var selected = GetSelectedScripts();
        if (selected.Count == 0) return;

        AuditState.StartExecution(1, selected.Count, false);
        AuditState.UpdateProgress(1, SelectedServer, 0, "Running...");
        AuditState.ClearExecutionResults();
        
        _runCts?.Dispose();
        _runCts = new CancellationTokenSource();
        var ct = _runCts.Token;
        StateHasChanged();

        try
        {
            var results = new List<ScriptExecutionResult>();
            int idx = 0;
            foreach (var script in selected)
            {
                if (ct.IsCancellationRequested) break;
                idx++;
                AuditState.UpdateProgress(1, SelectedServer, idx, script.Name);
                StateHasChanged();
                var result = await ScriptRunner.ExecuteScriptAsync(script, SelectedConnection, SelectedServer, ct);
                results.Add(result);
                AuditState.AddExecutionResult(result);
            }
            
            if (ct.IsCancellationRequested)
            {
                Toast.ShowWarning("Run cancelled by user.");
            }
            else
            {
                AuditState.UpdateProgress(1, SelectedServer, selected.Count, "Complete");
                Toast.ShowSuccess("Raw Diagnostics complete: " + SelectedServer + " — " + results.Count + " script(s) run");
            }
            
            await AutoExportAuditResults(results, SelectedServer);
            MaybeShowPostRunModal(results);
        }
        finally
        {
            AuditState.IsRunning = false;
        }
    }

    private void RequestRunAllServers()
    {
        if (GetSelectedScripts().Count == 0) return;
        _showParallelModal = true;
    }

    private void CancelParallelModal() => _showParallelModal = false;

    private void DismissPostRunModal() => _showPostRunModal = false;

    /// <summary>
    /// Surface anything the user should know about after a run: hard errors,
    /// scripts that returned no rows when CSV was expected, blocked scripts,
    /// warnings on ExecutionParameters. Auto-opens a modal so problems can't
    /// hide in per-card error text the user might miss (esp. for the
    /// sp_triage no-CSV case where Success=true + Results==null today).
    /// </summary>
    private void MaybeShowPostRunModal(IEnumerable<ScriptExecutionResult> results)
    {
        var issues = new List<PostRunIssue>();
        foreach (var r in results)
        {
            if (r is null) continue;
            if (!r.Success)
            {
                issues.Add(new PostRunIssue(r.ServerName, r.ScriptName, "Error",
                    string.IsNullOrWhiteSpace(r.ErrorMessage) ? "Script failed (no error message captured)." : r.ErrorMessage!));
                continue;
            }
            if (!string.IsNullOrWhiteSpace(r.ErrorMessage))
            {
                issues.Add(new PostRunIssue(r.ServerName, r.ScriptName, "Warning",
                    r.ErrorMessage!));
                continue;
            }
            
            // For multi-server runs, the ScriptName is prefixed with "[ServerName] " to ensure unique dictionary keys.
            var bareScriptName = r.ScriptName;
            if (bareScriptName.StartsWith("[") && bareScriptName.Contains("] "))
            {
                bareScriptName = bareScriptName.Substring(bareScriptName.IndexOf("] ") + 2);
            }
            
            var cfg = _scripts.FirstOrDefault(s => s.Name == bareScriptName);
            if (cfg != null && cfg.ExportToCsv && r.RowsAffected == 0)
            {
                issues.Add(new PostRunIssue(r.ServerName, r.ScriptName, "No-Rows",
                    "Script reported success but returned 0 rows for the CSV export query. " +
                    "The CSV file may be empty or missing. Check SqlQueryForOutput and the script's " +
                    "expected output."));
            }
        }
        _postRunIssues = issues;
        _showPostRunModal = issues.Count > 0;
    }

    /// <summary>Plain-text dump suitable for clipboard copy / email body.</summary>
    private string PostRunIssuesAsText()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"SQLTriage Raw Diagnostics — {_postRunIssues.Count} issue(s)");
        sb.AppendLine($"Captured: {DateTime.Now:yyyy-MM-dd HH:mm}");
        sb.AppendLine($"App version: {GetType().Assembly.GetName().Version}");
        sb.AppendLine();
        foreach (var i in _postRunIssues)
        {
            sb.AppendLine($"[{i.Severity}] {i.Server}  ::  {i.Script}");
            sb.AppendLine(i.Detail);
            sb.AppendLine();
        }
        return sb.ToString();
    }

    private async Task CopyAllIssuesAsync()
    {
        try { await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", PostRunIssuesAsText()); }
        catch (Exception ex) { Toast.ShowError("Copy failed: " + ex.Message); return; }
        Toast.ShowSuccess("Copied " + _postRunIssues.Count + " issue(s) to clipboard");
    }

    private async Task CopyOneIssueAsync(PostRunIssue issue)
    {
        var text = $"[{issue.Severity}] {issue.Server} :: {issue.Script}\n{issue.Detail}";
        try { await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text); }
        catch (Exception ex) { Toast.ShowError("Copy failed: " + ex.Message); return; }
        Toast.ShowSuccess("Copied 1 issue to clipboard");
    }

    private async Task ConfirmRun()
    {
        _showParallelModal = false;
        if (_parallelMode)
            await RunAgainstAllServersParallel();
        else
            await RunAgainstAllServers();
    }

    /// <summary>
    /// Starts each server's audit concurrently, staggered by _parallelDelaySeconds.
    /// Each server executes its scripts serially in order; results stream back as they complete.
    /// </summary>
    private async Task RunAgainstAllServersParallel()
    {
        var allServers = AllSuccessfulServers;
        if (allServers.Count == 0) return;
        var selected = GetSelectedScripts();
        if (selected.Count == 0) return;

        // Clear BEFORE start (see RunAgainstAllServers): clearing after StartExecution
        // resets _executionStartTime, hiding the Elapsed clock. Order matters.
        AuditState.ClearExecutionResults();
        AuditState.StartExecution(allServers.Count, selected.Count, true);

        _runCts?.Dispose();
        _runCts = new CancellationTokenSource();
        var ct = _runCts.Token;

        try
        {
            var tasks = new List<Task>();
            int serverIndex = 0;

            foreach (var (conn, server) in allServers)
            {
                serverIndex++;
                var capturedIndex  = serverIndex;
                var capturedConn   = conn;
                var capturedServer = server;

                // Stagger start: each server waits delay × (index-1) before beginning
                var startDelay = TimeSpan.FromSeconds(_parallelDelaySeconds * (capturedIndex - 1));

                tasks.Add(Task.Run(async () =>
                {
                    if (startDelay > TimeSpan.Zero)
                        await Task.Delay(startDelay, ct);

                    await InvokeAsync(() =>
                    {
                        AuditState.UpdateProgress(capturedIndex, capturedServer, 0, "");
                        StateHasChanged();
                    });

                    var results = new List<ScriptExecutionResult>();
                    int scriptIndex = 0;

                    foreach (var script in selected)
                    {
                        if (ct.IsCancellationRequested) break;
                        scriptIndex++;
                        await InvokeAsync(() =>
                        {
                            AuditState.UpdateProgress(capturedIndex, capturedServer, scriptIndex, script.Name);
                            StateHasChanged();
                        });

                        var result = await ScriptRunner.ExecuteScriptAsync(script, capturedConn, capturedServer, ct);
                        result.ScriptName = "[" + capturedServer + "] " + result.ScriptName;
                        results.Add(result);

                        await InvokeAsync(() =>
                        {
                            AuditState.AddExecutionResult(result);
                            StateHasChanged();
                        });
                    }

                    if (!ct.IsCancellationRequested)
                    {
                        await InvokeAsync(() =>
                        {
                            Toast.ShowInfo("Raw Diagnostics: " + capturedServer + " complete (" + results.Count + " scripts, " + capturedIndex + "/" + allServers.Count + ")");
                            StateHasChanged();
                        });
                    }

                    await AutoExportAuditResults(results, capturedServer);
                }, ct));
            }

            try { await Task.WhenAll(tasks); } catch (OperationCanceledException) { }
            
            if (ct.IsCancellationRequested) Toast.ShowWarning("Run cancelled by user.");
            else MaybeShowPostRunModal(AuditState.GetAllExecutionResults());
        }
        finally
        {
            AuditState.IsRunning = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunAgainstAllServers()
    {
        var allServers = AllSuccessfulServers;
        if (allServers.Count == 0) return;
        var selected = GetSelectedScripts();
        if (selected.Count == 0) return;

        // Clear BEFORE start: ClearExecutionResults() calls ResetProgress() which
        // nulls _executionStartTime. Clearing after StartExecution wiped the start
        // time, so ElapsedTime read 0 and the "Elapsed" clock never showed on
        // all-servers runs. Order matters.
        AuditState.ClearExecutionResults();
        AuditState.StartExecution(allServers.Count, selected.Count, true);

        _runCts?.Dispose();
        _runCts = new CancellationTokenSource();
        var ct = _runCts.Token;

        try
        {
            var groupedByConnection = allServers.GroupBy(s => s.Connection.Id);
            int serverIndex = 0;

            foreach (var group in groupedByConnection)
            {
                if (ct.IsCancellationRequested) break;
                var connection = group.First().Connection;
                foreach (var (conn, server) in group)
                {
                    if (ct.IsCancellationRequested) break;
                    serverIndex++;
                    AuditState.UpdateProgress(serverIndex, server, 0, "");

                    var results = new List<ScriptExecutionResult>();
                    int scriptIndex = 0;
                    foreach (var script in selected)
                    {
                        if (ct.IsCancellationRequested) break;
                        scriptIndex++;
                        AuditState.UpdateProgress(serverIndex, server, scriptIndex, script.Name);
                        StateHasChanged();
                        var result = await ScriptRunner.ExecuteScriptAsync(script, conn, server, ct);
                        result.ScriptName = "[" + server + "] " + result.ScriptName;
                        results.Add(result);
                        AuditState.AddExecutionResult(result);
                    }
                    if (!ct.IsCancellationRequested)
                    {
                        Toast.ShowInfo("Raw Diagnostics: " + server + " complete (" + results.Count + " scripts, " + serverIndex + "/" + allServers.Count + ")");
                    }
                    await AutoExportAuditResults(results, server);
                }
            }
            if (ct.IsCancellationRequested) Toast.ShowWarning("Run cancelled by user.");
            else MaybeShowPostRunModal(AuditState.GetAllExecutionResults());
        }
        finally
        {
            AuditState.IsRunning = false;
        }
    }

    private async Task RunScript(ScriptConfiguration script)
    {
        if (SelectedServer == null || SelectedConnection == null) return;

        AuditState.StartExecution(1, 1, false);
        AuditState.UpdateProgress(1, SelectedServer, 0, script.Name);

        _runCts?.Dispose();
        _runCts = new CancellationTokenSource();
        var ct = _runCts.Token;

        try
        {
            var result = await ScriptRunner.ExecuteScriptAsync(script, SelectedConnection, SelectedServer, ct);
            AuditState.RemoveExecutionResult(script.Name);
            AuditState.AddExecutionResult(result);
            if (ct.IsCancellationRequested) Toast.ShowWarning("Run cancelled by user.");
        }
        finally
        {
            AuditState.IsRunning = false;
        }
    }

    private ScriptExecutionResult? GetResultForScript(string scriptName)
    {
        return _executionResults.FirstOrDefault(r => r.ScriptName == scriptName);
    }

    private async Task AutoExportAuditResults(List<ScriptExecutionResult> results, string serverName)
    {
        try
        {
            var settings = UserSettings.GetSettings();
            if (!settings.AutoExportAuditCsv && !settings.AutoExportAuditJson) return;

            var outputDir = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "output");
            Directory.CreateDirectory(outputDir);
            var timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");
            var safeServer = serverName.Replace(@"\", "_").Replace("/", "_").Replace(":", "_");

            if (settings.AutoExportAuditCsv)
            {
                var csv = new StringBuilder();
                csv.AppendLine("Server,Script,Success,RowsAffected,ExecutionTime,ErrorMessage");
                foreach (var r in results)
                {
                    var error = (r.ErrorMessage ?? "").Replace("\"", "\"\"");
                    var execSec = r.ExecutionTime.TotalSeconds.ToString("F1");
                    csv.AppendLine("\"" + safeServer + "\",\"" + r.ScriptName + "\"," + r.Success + "," + r.RowsAffected + "," + execSec + ",\"" + error + "\"");

                    if (r.Success && r.Results != null && r.Results.Count > 0)
                    {
                        var scriptCsv = new StringBuilder();
                        var headers = r.Results[0].Keys.ToList();
                        scriptCsv.AppendLine(string.Join(",", headers.Select(h => "\"" + h + "\"")));
                        foreach (var row in r.Results)
                        {
                            var vals = headers.Select(h =>
                            {
                                var v = row.TryGetValue(h, out var val) ? val?.ToString() ?? "" : "";
                                return "\"" + v.Replace("\"", "\"\"") + "\"";
                            });
                            scriptCsv.AppendLine(string.Join(",", vals));
                        }
                        var scriptFileName = "FullAudit_" + safeServer + "_" + r.ScriptName.Replace(" ", "_") + "_" + timestamp + ".csv";
                        await File.WriteAllTextAsync(Path.Combine(outputDir, scriptFileName), scriptCsv.ToString());
                    }
                }
                var summaryFile = "FullAudit_" + safeServer + "_Summary_" + timestamp + ".csv";
                await File.WriteAllTextAsync(Path.Combine(outputDir, summaryFile), csv.ToString());
                Toast.ShowInfo("Audit CSV exported: " + safeServer);
            }

            if (settings.AutoExportAuditJson)
            {
                var jsonFile = "FullAudit_" + safeServer + "_" + timestamp + ".json";
                var jsonOpts = new JsonSerializerOptions { WriteIndented = true };
                var json = JsonSerializer.Serialize(results, jsonOpts);
                await File.WriteAllTextAsync(Path.Combine(outputDir, jsonFile), json);
                Toast.ShowInfo("Audit JSON exported: " + safeServer);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Auto-export failed for server: " + serverName);
        }
    }

    private async void DownloadFile(string content, string fileName)
    {
        try
        {
            var bytes = Encoding.UTF8.GetBytes(content);
            var base64 = Convert.ToBase64String(bytes);

            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, base64);
            Logger.LogInformation("Download triggered for {FileName}", fileName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error triggering download for {FileName}", fileName);
        }
    }

    // ── Manual CSV/PDF export ────────────────────────────────────────────────

    private static string CsvQuote(string? v)
    {
        if (string.IsNullOrEmpty(v)) return "";
        if (v.IndexOfAny(new[] { ',', '"', '\n', '\r' }) < 0) return v;
        return "\"" + v.Replace("\"", "\"\"") + "\"";
    }

    private void ExportSummaryCsvAsync()
    {
        try
        {
            var results = _executionResults;
            var sb = new StringBuilder();
            sb.AppendLine("ServerName,ScriptName,Success,RowsAffected,ExecutionTimeSec,StatusMessage,ErrorMessage");
            foreach (var r in results)
            {
                sb.AppendLine(string.Join(",",
                    CsvQuote(r.ServerName),
                    CsvQuote(r.ScriptName),
                    r.Success.ToString(),
                    r.RowsAffected.ToString(),
                    r.ExecutionTime.TotalSeconds.ToString("F2"),
                    CsvQuote(r.StatusMessage),
                    CsvQuote(r.ErrorMessage)));
            }

            var downloadsDir = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
            var exportDir = Path.Combine(downloadsDir, "Downloads");
            if (!Directory.Exists(exportDir)) exportDir = AppDomain.CurrentDomain.BaseDirectory;

            var fileName = $"FullAudit_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            var filePath = Path.Combine(exportDir, fileName);
            File.WriteAllText(filePath, sb.ToString(), Encoding.UTF8);

            AuditLog.LogExportOperation("CSV", "FullAudit", true);
            Toast.ShowSuccess($"CSV exported ({results.Count} rows): {fileName}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "CSV export failed");
            AuditLog.LogExportOperation("CSV", "FullAudit", false, ex.Message);
            Toast.ShowError($"CSV export failed: {ex.Message}");
        }
    }

    private SQLTriage.Components.Shared.PdfExportModal _pdfModal = default!;
    private bool _pdfExporting;

    private void OpenPdfModal()
    {
        var stem = $"FullAudit_{DateTime.Now:yyyyMMdd_HHmmss}";
        _pdfModal.Show(stem);
    }

    private async Task OnPdfConfirmed(SQLTriage.Data.Models.PdfExportSettings settings)
    {
        await Task.Delay(350);
        _pdfExporting = true;
        StateHasChanged();
        try
        {
            if (!PrintSvc.IsAvailable)
            {
                await PrintSvc.PrintViaBrowserAsync(JSRuntime);
                Toast.ShowInfo("Browser print dialog opened — use 'Save as PDF' to export.");
                return;
            }

            var orientation = settings.LandscapeOrientation
                ? Microsoft.Web.WebView2.Core.CoreWebView2PrintOrientation.Landscape
                : Microsoft.Web.WebView2.Core.CoreWebView2PrintOrientation.Portrait;

            // Watermark: apply when the selected connection is non-production or unset,
            // unless the user toggled Release mode in the export modal.
            var applyWatermark = !settings.SuppressWatermark &&
                ServerEnvironment.RequiresWatermark(
                    new[] { SelectedConnection?.Environment });
            if (applyWatermark)
                await JSRuntime.InvokeVoidAsync("eval", "document.body.classList.add('has-draft-watermark');");

            var (success, path, error) = await PrintSvc.PrintToPdfAsync(settings.FileName,
                printBackgrounds: settings.PrintBackgrounds,
                orientation: orientation);

            if (applyWatermark)
                await JSRuntime.InvokeVoidAsync("eval", "document.body.classList.remove('has-draft-watermark');");

            if (success)
            {
                AuditLog.LogExportOperation("PDF", "FullAudit", true);
                Toast.ShowSuccess($"PDF saved: {System.IO.Path.GetFileName(path)}");
            }
            else
            {
                AuditLog.LogExportOperation("PDF", "FullAudit", false, error);
                Toast.ShowError($"PDF export failed: {error}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "PDF export failed");
            AuditLog.LogExportOperation("PDF", "FullAudit", false, ex.Message);
            Toast.ShowError($"PDF export failed: {ex.Message}");
        }
        finally
        {
            _pdfExporting = false;
            StateHasChanged();
        }
    }
