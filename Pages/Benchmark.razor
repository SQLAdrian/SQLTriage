<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/benchmark"
<PageTitle>SQLTriage - Benchmark</PageTitle>
@inject ServerConnectionManager ConnectionManager
@inject SQLTriage.Data.Services.BenchmarkService BenchmarkService
@inject IJSRuntime JS
@inject SQLTriage.Data.ToastService Toast
@using SQLTriage.Data.Services

<div class="benchmark-page">
    <div class="page-header">
        <h1><i class="fa-solid fa-gauge-high" style="color:var(--accent);"></i> SQL Server Performance Benchmark</h1>
        <p>Run CPU and latency benchmarks across your SQL Server instances to identify hardware bottlenecks and hypervisor contention.</p>
    </div>

    @if (_isRunning)
    {
        <div class="benchmark-progress">
            <div class="progress-bar">
                <div class="progress-fill" style="width: @(_progressPercent)%"></div>
            </div>
            <span class="progress-text">@_currentOperation</span>
        </div>
    }

    @* ── Comparison grid (multi-server view) ── *@
    @if (_comparisonRows.Count > 0 && _allServers.Count >= 2)
    {
        <div class="benchmark-results">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
                <h2>Comparison Grid</h2>
                <button class="btn btn-sm btn-secondary" @onclick="ExportCsv" title="Export comparison as CSV">
                    <i class="fa-solid fa-file-csv"></i> CSV
                </button>
            </div>

            @if (_allServers.Count > 1)
            {
                <div style="margin-bottom:10px;font-size:12px;color:var(--text-secondary);">
                    Baseline: <select @bind="_baselineServer" @bind:event="onchange" style="background:var(--bg-primary);color:var(--text-primary);border:1px solid var(--border);border-radius:4px;padding:2px 6px;font-size:12px;">
                        @foreach (var s in _allServers)
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                    <span style="margin-left:8px;">Deltas shown vs baseline. </span>
                    <span class="calibration-todo" title="Thresholds are indicative and subject to workload tuning. Use CSV export for offline analysis.">?</span>
                </div>
            }

            <div class="results-table-container">
                <table class="benchmark-table comparison-grid">
                    <thead>
                        <tr>
                            <th>Metric</th>
                            @foreach (var server in _allServers)
                            {
                                <th>
                                    @server
                                    @if (server == _baselineServer)
                                    {
                                        <span style="font-size:10px;color:var(--accent);margin-left:4px;">(base)</span>
                                    }
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _comparisonRows)
                        {
                            <tr>
                                <td class="metric-label">
                                    @row.MetricLabel
                                    <span class="calibration-todo" title="Thresholds are indicative and subject to workload tuning. Use CSV export for offline analysis.">?</span>
                                </td>
                                @foreach (var server in _allServers)
                                {
                                    var cell = row.Servers.GetValueOrDefault(server);
                                    var deltaPct = cell.DeltaPct;
                                    var heatClass = GetHeatClass(row.MetricKey, deltaPct);
                                    <td class="metric-cell @heatClass" title="@GetCellTitle(cell.Value, row.Unit, deltaPct)">
                                        <span class="cell-value">@(cell.Value.ToString("F1"))@row.Unit</span>
                                        @if (deltaPct.HasValue)
                                        {
                                            <span class="cell-delta @(Math.Abs(deltaPct.Value) > 5 ? "delta-flag" : "")">
                                                @(deltaPct.Value > 0 ? "+" : "")@(deltaPct.Value.ToString("F1"))%
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="cell-delta">—</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* ── Single-server results ── *@
    @if (_benchmarkResults.Count > 0 && _allServers.Count < 2)
    {
        <div class="benchmark-results">
            <h2>Benchmark Results</h2>
            <div class="results-table-container">
                <table class="benchmark-table">
                    <thead>
                        <tr>
                            <th>Server</th>
                            <th>CPU Integer<br/><small>(&lt; 100ms = Fast)</small></th>
                            <th>String Ops<br/><small>(&lt; 200ms = Fast)</small></th>
                            <th>Memory Access</th>
                            <th>Signal Wait %<br/><small>(&lt; 25% = Good)</small></th>
                            <th>Runnable Tasks</th>
                            <th>Overall</th>
                            <th>Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var result in _benchmarkResults.OrderByDescending(r => r.Timestamp))
                        {
                            <tr>
                                <td>@result.ServerName</td>
                                <td class="@GetRatingClass(result.CpuRating)">@result.CpuIntegerBenchmarkMs.ToString("F1")ms<br/><small>@result.CpuRating</small></td>
                                <td class="@GetRatingClass(result.StringOpsRating)">@result.StringOpsBenchmarkMs.ToString("F1")ms<br/><small>@result.StringOpsRating</small></td>
                                <td>@result.MemoryAccessBenchmarkMs.ToString("F1")ms</td>
                                <td class="@GetRatingClass(result.SignalWaitPercentage < 25 ? "Good" : "Poor")">@result.SignalWaitPercentage.ToString("F1")%<br/><small>@result.HypervisorRating</small></td>
                                <td>@result.CpuSchedulerDelayMs.ToString("F2")ms</td>
                                <td class="@GetOverallRatingClass(result)">@GetOverallRating(result)</td>
                                <td>@result.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* ── Run controls ── *@
    <div class="benchmark-controls">
        <h2>Run Benchmarks</h2>
        <div class="server-selection">
            @foreach (var conn in _enabledConnections)
            {
                <div class="server-benchmark-item">
                    <div class="server-info">
                        <strong>@conn.ServerNames</strong>
                        <br/><small>@conn.Database</small>
                    </div>
                    <button class="btn btn-primary @(_runningServers.Contains(conn.Id) ? "active" : "")"
                            @onclick="() => RunBenchmarkForServer(conn)"
                            disabled="@_isRunning">
                        @if (_runningServers.Contains(conn.Id))
                        {
                            <i class="fa-solid fa-spinner fa-spin"></i>
                            <span>Running…</span>
                        }
                        else
                        {
                            <i class="fa-solid fa-gauge-high"></i>
                            <span>Run Benchmark</span>
                        }
                    </button>
                </div>
            }
        </div>

        @if (_enabledConnections.Count > 1)
        {
            <div class="bulk-actions">
                <button class="btn btn-success" @onclick="RunAllBenchmarks" disabled="@_isRunning">
                    <i class="fa-solid fa-play"></i> Run All Benchmarks
                </button>
            </div>
        }
    </div>

    <div class="benchmark-info">
        <h3>About These Benchmarks</h3>
        <div class="info-grid">
            <div class="info-item">
                <h4>CPU Integer Arithmetic</h4>
                <p>Measures raw CPU performance through mathematical calculations. Slow results may indicate CPU contention or over-subscription.</p>
            </div>
            <div class="info-item">
                <h4>String Operations</h4>
                <p>Tests string processing performance. Affected by CPU cores, memory bandwidth, and SQL Server's string handling.</p>
            </div>
            <div class="info-item">
                <h4>Signal Wait Percentage</h4>
                <p>Indicates CPU scheduling delays. High values (>25%) suggest hypervisor contention in virtualized environments. <span class="calibration-todo" title="5% threshold is indicative and subject to workload tuning.">?</span></p>
            </div>
            <div class="info-item">
                <h4>Memory Access</h4>
                <p>Simulated memory latency through DMV queries. Helps identify NUMA issues or memory contention.</p>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ServerConnection> _enabledConnections = new();
    private List<BenchmarkResult> _benchmarkResults = new();
    private List<ComparisonRow> _comparisonRows = new();
    private List<string> _allServers = new();
    private string _baselineServer = "";
    private bool _isRunning = false;
    private double _progressPercent = 0;
    private string _currentOperation = "";
    private HashSet<string> _runningServers = new();

    private class ComparisonRow
    {
        public string MetricKey { get; init; } = "";
        public string MetricLabel { get; init; } = "";
        public string Unit { get; init; } = "";
        public Dictionary<string, (double Value, double? DeltaPct)> Servers { get; init; } = new();
    }

    protected override void OnInitialized()
    {
        LoadConnections();
        ReloadComparisonData();
    }

    private void LoadConnections()
    {
        _enabledConnections = ConnectionManager.GetConnections()
            .Where(c => c.IsEnabled)
            .ToList();
    }

    private void ReloadComparisonData()
    {
        var runs = BenchmarkService.GetLatestRuns();
        if (runs.Count == 0) return;

        _allServers = runs.Select(r => r.ServerName).Distinct().OrderBy(s => s).ToList();
        if (string.IsNullOrEmpty(_baselineServer) || !_allServers.Contains(_baselineServer))
            _baselineServer = _allServers.FirstOrDefault() ?? "";

        var metricDefs = new (string key, string label, string unit)[]
        {
            ("cpu_integer_ms",     "CPU Integer",     "ms"),
            ("string_ops_ms",      "String Ops",      "ms"),
            ("memory_access_ms",   "Memory Access",   "ms"),
            ("signal_wait_pct",    "Signal Wait",     "%"),
            ("scheduler_runnable_avg", "Runnable Tasks",  "tasks"),
        };

        _comparisonRows = new List<ComparisonRow>();
        foreach (var (key, label, unit) in metricDefs)
        {
            var row = new ComparisonRow { MetricKey = key, MetricLabel = label, Unit = unit };
            var valuesByServer = runs
                .Where(r => r.MetricName == key)
                .ToDictionary(r => r.ServerName, r => r.ValueNumeric);

            var baselineValue = valuesByServer.GetValueOrDefault(_baselineServer, double.NaN);

            foreach (var server in _allServers)
            {
                var value = valuesByServer.GetValueOrDefault(server, 0);
                double? deltaPct = null;
                if (!double.IsNaN(baselineValue) && baselineValue != 0 && server != _baselineServer)
                    deltaPct = (value - baselineValue) / baselineValue * 100.0;

                row.Servers[server] = (value, deltaPct);
            }

            _comparisonRows.Add(row);
        }
    }

    private async Task RunBenchmarkForServer(ServerConnection conn)
    {
        if (_isRunning) return;
        _runningServers.Add(conn.Id);
        _isRunning = true;
        _progressPercent = 0;
        _currentOperation = $"Benchmarking {conn.ServerNames}…";

        try
        {
            StateHasChanged();
            await Task.Delay(50);

            _progressPercent = 20;
            _currentOperation = "Running CPU integer benchmark…";
            StateHasChanged();

            _progressPercent = 40;
            _currentOperation = "Running string operations benchmark…";
            StateHasChanged();

            _progressPercent = 60;
            _currentOperation = "Running memory access benchmark…";
            StateHasChanged();

            _progressPercent = 80;
            _currentOperation = "Analyzing signal wait patterns…";
            StateHasChanged();

            var result = await BenchmarkService.RunBenchmarkAsync(conn.ServerNames, conn.Database);

            if (result.Success)
            {
                _benchmarkResults.Add(result);
                _progressPercent = 100;
                _currentOperation = $"Benchmark completed for {conn.ServerNames}";
                ReloadComparisonData();
                Toast.ShowSuccess($"Benchmark completed for {conn.ServerNames}");
            }
            else
            {
                Toast.ShowError($"Benchmark failed for {conn.ServerNames}: {result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Benchmark failed for {conn.ServerNames}: {ex.Message}");
        }
        finally
        {
            _runningServers.Remove(conn.Id);
            _isRunning = false;
            _progressPercent = 0;
            _currentOperation = "";
            StateHasChanged();
        }
    }

    private async Task RunAllBenchmarks()
    {
        if (_isRunning) return;
        foreach (var conn in _enabledConnections)
        {
            await RunBenchmarkForServer(conn);
            await Task.Delay(500);
        }
    }

    private string GetRatingClass(string rating) => rating.ToLower() switch
    {
        "fast" or "good" or "low contention" => "rating-fast",
        "normal" or "moderate contention" => "rating-normal",
        "poor" or "high contention" => "rating-poor",
        _ => "rating-degraded"
    };

    private string GetOverallRatingClass(BenchmarkResult result)
    {
        var ratings = new[] { result.CpuRating, result.StringOpsRating, result.HypervisorRating };
        var goodCount = ratings.Count(r => r.Contains("Fast") || r.Contains("Good") || r.Contains("Low"));
        var poorCount = ratings.Count(r => r.Contains("Degraded") || r.Contains("Poor") || r.Contains("High"));
        if (goodCount >= 2) return "rating-good";
        if (poorCount >= 2) return "rating-poor";
        return "rating-normal";
    }

    private string GetOverallRating(BenchmarkResult result)
    {
        return GetOverallRatingClass(result) switch
        {
            "rating-good" => "Good",
            "rating-poor" => "Needs Attention",
            _ => "Average"
        };
    }

    private string GetHeatClass(string metricKey, double? deltaPct)
    {
        if (deltaPct == null) return "heat-neutral";
        var abs = Math.Abs(deltaPct.Value);
        var isWorse = deltaPct.Value > 0;
        if (abs < 5) return "heat-neutral";
        if (abs < 20) return isWorse ? "heat-warm" : "heat-cool";
        return isWorse ? "heat-hot" : "heat-cold";
    }

    private static string GetCellTitle(double value, string unit, double? deltaPct)
    {
        var title = $"Value: {value:F2}{unit}";
        if (deltaPct.HasValue)
            title += $"  Delta vs baseline: {deltaPct.Value:+#0.0;-#0.0;0}%";
        return title;
    }

    private void ExportCsv()
    {
        if (_comparisonRows.Count == 0) return;
        var csv = new System.Text.StringBuilder();
        csv.Append("Metric,");
        csv.Append(string.Join(",", _allServers.Select(s => $"\"{s}\"")));
        csv.AppendLine();

        foreach (var row in _comparisonRows)
        {
            csv.Append($"\"{row.MetricLabel} ({row.Unit})\",");
            var values = _allServers.Select(s =>
            {
                var cell = row.Servers.GetValueOrDefault(s);
                return cell.Value.ToString("F2");
            });
            csv.AppendLine(string.Join(",", values));
        }

        // Trigger download via JS
        _ = JS.InvokeVoidAsync("eval",
            $"var blob = new Blob([`{csv.ToString()}`], {{type:'text/csv'}});" +
            "var a = document.createElement('a');" +
            "a.href = URL.createObjectURL(blob);" +
            "a.download = 'benchmark_comparison.csv';" +
            "a.click();");
        Toast.ShowInfo("CSV exported. Use for offline threshold calibration.");
    }
}
