<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/governance"
@using SQLTriage.Components.Shared
@using SQLTriage.Data
@using SQLTriage.Data.Models
@using SQLTriage.Data.Services
@using static SQLTriage.Data.Services.GovernanceService
@using Microsoft.Data.SqlClient
@using System.Data
@inject IGovernanceService GovernanceService
@inject IFindingTranslator FindingTranslator
@inject CheckExecutionService CheckExecutor
@inject IQuickCheckRunner QuickCheckRunner
@inject ServerConnectionManager ConnectionManager
@inject NavigationManager Navigation
@inject ToastService Toast
@inject IPrintService PrintService
@inject IJSRuntime JS

<PageTitle>Governance - SQLTriage</PageTitle>

<div class="governance-container @(_dataGridMode ? "data-grid-mode" : "")">
    <div class="governance-header">
        <h1>SQL Server Governance</h1>
        <p>Health assessment and compliance overview</p>
    </div>

    <!-- Indicative Check Banner -->
    @if (_isIndicative)
    {
        <div class="indicative-banner">
            <i class="fa-solid fa-info-circle"></i>
            <span>This is an <strong>indicative assessment</strong> from the Audit Assessment (≤60 seconds). Run a full Vulnerability Assessment for complete governance scoring.</span>
        </div>
    }

    <!-- Status Overview -->
    @if (_governanceScore != null)
    {
        <div class="score-overview card-glass" style="display:flex; flex-direction:row; justify-content:space-between; align-items:center; padding:20px 30px; gap:24px; margin-bottom: 24px;">
            <div style="display:flex; align-items:center; gap:32px;">
                <div style="display:flex; flex-direction:column;">
                    <span style="font-size:12px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.5px; font-weight:600; margin-bottom:4px;">Governance Score</span>
                    <div style="display:flex; align-items:baseline; gap:12px;">
                        <span style="font-size:48px; font-weight:800; color:var(--text-primary); line-height:1; font-family:var(--font-display, inherit);">@_governanceScore.Overall.ToString("F0")</span>
                        <span style="font-size:16px; color:var(--text-secondary); font-weight:600;">@_governanceScore.Band</span>
                    </div>
                </div>
                @if (_isIndicative)
                {
                    <div style="background:var(--accent); color:#000; font-weight:800; padding:4px 10px; border-radius:4px; font-size:12px; letter-spacing:1px;">
                        INDICATIVE
                    </div>
                }
            </div>

            <div style="display:flex; gap:40px; border-left:1px solid var(--border); padding-left:40px;">
                <div style="display:flex; flex-direction:column; align-items:flex-start;">
                    <span style="font-size:12px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.5px; font-weight:600; margin-bottom:4px;">Total Checks</span>
                    <span style="font-size:28px; font-weight:600; color:var(--text-primary); font-family:var(--font-display, inherit);">@_governanceScore.TotalFindings</span>
                </div>
                <div style="display:flex; flex-direction:column; align-items:flex-start;">
                    <span style="font-size:12px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.5px; font-weight:600; margin-bottom:4px;">Passed</span>
                    <span style="font-size:28px; font-weight:600; color:var(--green); font-family:var(--font-display, inherit);">@_governanceScore.PassedFindings</span>
                </div>
                <div style="display:flex; flex-direction:column; align-items:flex-start;">
                    <span style="font-size:12px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.5px; font-weight:600; margin-bottom:4px;">Failed</span>
                    <span style="font-size:28px; font-weight:600; color:var(--red); font-family:var(--font-display, inherit);">@_governanceScore.FailedFindings</span>
                </div>
            </div>
        </div>
    }
    else
    {
        <PageLoadingSpinner Message="Computing governance score..." />
    }

    <!-- Compliance Timeline (Phase 5) -->
    @if (_findings.Any())
    {
        <div class="timeline-section">
            <h3 style="margin-bottom: 0;">Compliance Maturity Framework</h3>
            <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 0;">Mapping of ruleset gaps against standard compliance controls.</p>
            <SQLTriage.Components.Shared.GovernanceTimeline Findings="_findings" />
        </div>
    }

    <div class="action-buttons">
        <button class="btn @(_dataGridMode ? "btn-primary" : "btn-secondary")" @onclick="() => _dataGridMode = !_dataGridMode">
            <i class="fa-solid fa-table"></i> Data Grid
        </button>
                @if (_isIndicative)
        {
            <button class="btn btn-primary" @onclick="RunFullAssessment">
                <i class="fa-solid fa-search"></i> Run Full Vulnerability Assessment
            </button>
        }
        <button class="btn btn-secondary" @onclick="ExportPdf">
            <i class="fa-solid fa-file-pdf"></i> Export PDF
        </button>
        <button class="btn btn-secondary" @onclick="RunQuickCheck">
            <i class="fa-solid fa-refresh"></i> Re-run Audit Assessment
        </button>
        @if (BuildModules.DevTools)
        {
            <button class="btn btn-info" @onclick="NavigateToValidator">
                <i class="fa-solid fa-external-link"></i> Open Check Validator
            </button>
        }
    </div>

    <!-- Findings — two voices per finding (DBA + governance) -->
    @if (_translations.Any())
    {
        <div class="findings-section">
            <h3>Key Findings — DBA &amp; governance views</h3>
            <div class="findings-list">
                @for (var i = 0; i < _translations.Count; i++)
                {
                    var t = _translations[i];
                    var sev = i < _findings.Count ? _findings[i].Severity : "";
                    <div class="finding-item severity-@sev.ToLowerInvariant()">
                        <div class="finding-header">
                            <span class="finding-title">@t.CheckName</span>
                            <span class="finding-severity">@sev</span>
                        </div>
                        <div class="finding-voices">
                            <div class="finding-voice finding-voice-dba">
                                <h4><i class="fa-solid fa-terminal"></i> DBA view</h4>
                                <div class="finding-description">@((MarkupString)Markdig.Markdown.ToHtml(t.Dba.TechnicalDetails ?? ""))</div>
                                @if (!string.IsNullOrWhiteSpace(t.Dba.TSqlRemediation))
                                {
                                    <div class="voice-tsql" style="margin-top: 12px;">
                                        @((MarkupString)Markdig.Markdown.ToHtml(
                                            t.Dba.TSqlRemediation.Contains("```") 
                                            ? t.Dba.TSqlRemediation 
                                            : "```sql\n" + t.Dba.TSqlRemediation + "\n```"
                                        ))
                                    </div>
                                }
                            </div>
                            <div class="finding-voice finding-voice-gov">
                                <h4 style="margin-top: 24px;"><i class="fa-solid fa-building-columns"></i> Governance view</h4>
                                <div class="finding-description">@((MarkupString)Markdig.Markdown.ToHtml(t.Executive.PlainLanguageSummary ?? ""))</div>
                                <div class="finding-action"><strong>Risk:</strong> @t.Executive.BusinessRisk</div>
                                <div class="finding-action"><strong>Controls:</strong> @t.Executive.ComplianceControls</div>
                                <div class="finding-action"><strong>Recommended:</strong> @t.Executive.RecommendedAction</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Loading State -->
    @if (_loading)
    {
        <LoadingSpinner Message="@_loadingMessage" />
    }
</div>

<!-- Styles extracted to wwwroot/css/Governance.css 2026-05-11 (CLAUDE.md convention).
     Imported via app.css @import "Governance.css". -->

@code {
    private bool _dataGridMode = false;
    private bool _isIndicative = false;
    private GovernanceScore? _governanceScore;
    private List<CheckResult> _findings = new();
    private List<FindingTranslation> _translations = new();
    private bool _loading = false;
    private string _loadingMessage = "";

    protected override async Task OnInitializedAsync()
    {
        // Check if this is from a quick check (indicated by query parameter)
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _isIndicative = queryParams.TryGetValue("IsIndicative", out var indicativeValue) && string.Equals(indicativeValue, "true", StringComparison.OrdinalIgnoreCase);

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _loadingMessage = "Loading governance data...";

        try
        {
            // Real data: the last in-memory check results across every connected server
            // (the same source the CIO dashboard scores from). With no scan yet, ComputeIndicative
            // returns a 0/Emerging score and the Key Findings section stays hidden — the action
            // buttons prompt the user to run an assessment.
            var results = new List<CheckResult>();
            foreach (var conn in ConnectionManager.GetEnabledConnections())
            {
                foreach (var server in conn.GetServerList())
                {
                    try
                    {
                        var rs = CheckExecutor.GetResults(server, 500);
                        if (rs.Count > 0) results.AddRange(rs);
                    }
                    catch { /* non-fatal per server */ }
                }
            }

            _governanceScore = await GovernanceService.ComputeIndicativeAsync(results);

            _findings = results
                .Where(r => !r.Passed)
                .OrderByDescending(r => SeverityRank(r.Severity))
                .ToList();

            // Per-finding dual-voice translation (offline rules engine — no LLM) for the top
            // findings: the DBA voice (what/why + T-SQL) and the governance voice (risk, controls)
            // side by side. This is the translation layer FindingTranslator was built for.
            _translations = _findings.Count > 0
                ? await FindingTranslator.TranslateFindingsAsync(_findings.Take(8))
                : new();
        }
        catch (Exception ex)
        {
            Toast.ShowError("Failed to load governance data", ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private static int SeverityRank(string? severity) => severity?.ToLowerInvariant() switch
    {
        "error" or "critical" => 4,
        "high" => 3,
        "warning" or "medium" => 2,
        "low" => 1,
        _ => 0
    };

    private async Task RunQuickCheck()
    {
        // Get the first connected server
        var connection = ConnectionManager.GetEnabledConnections().FirstOrDefault();
        if (connection == null)
        {
            Toast.ShowWarning("No server connection", "Please configure a server connection first.");
            Navigation.NavigateTo(RouteConstants.Servers);
            return;
        }

        _loading = true;
        _loadingMessage = "Running Audit Assessment...";

        try
        {
            var progress = new Progress<QuickCheckProgress>(p =>
            {
                _loadingMessage = $"Running Audit Assessment... ({p.Completed}/{p.Total})";
                StateHasChanged();
            });

            var result = await QuickCheckRunner.RunAsync(connection, connection.ServerNames.Split(',')[0], progress);
            Toast.ShowSuccess("Audit Assessment complete", $"{result.Summary.Passed}/{result.Summary.TotalChecks} passed");

            // Reload data
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError("Audit Assessment failed", ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private void RunFullAssessment()
    {
        // Navigate to full vulnerability assessment
        Navigation.NavigateTo(RouteConstants.VulnerabilityAssessment);
    }

    // dev-tools module: the invoking button is BuildModules.DevTools-gated (never renders in
    // community); the body is fenced too so the /check-validator route literal never reaches
    // a community assembly. The method itself must stay — unreachable markup is still bound.
    private void NavigateToValidator()
    {
#if !SQLT_NO_DEVTOOLS
        Navigation.NavigateTo(RouteConstants.CheckValidator);
#endif
    }
    private async Task ExportPdf()
    {
        _loading = true;
        _loadingMessage = "Generating PDF...";
        StateHasChanged();
        
        try 
        {
            await Task.Delay(100);
            var result = await PrintService.PrintToPdfAsync("Governance_Report.pdf", true);
            if (result.Success)
            {
                Toast.ShowSuccess("PDF Exported", "Saved to " + result.Path);
            }
            else 
            {
                // Fallback to browser print if no webview
                await PrintService.PrintViaBrowserAsync(JS);
            }
        }
        finally
        {
            _loading = false;
        }
    }
}
