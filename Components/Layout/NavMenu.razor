/* ── Per-category accent colours ──────────────────────────────────────────
   Colour is REDUNDANT coding here (every category also has its own icon +
   text label), so it never carries meaning alone — inherently colour-blind
   friendly. Under colour-blind mode the palette swaps to Wong (2011). */
:root {
    --cat-governance:   #6366f1; /* indigo */
    --cat-operations:   #2dd4bf; /* teal   */
    --cat-diagnostics:  #f59e0b; /* amber  */
    --cat-premium:      #c084fc; /* purple */
    --cat-intelligence: #22d3ee; /* cyan   */
    --cat-config:       #94a3b8; /* slate  */
    --cat-apply:        #ef4444; /* red — write/modify actions */
}
body.colorblind-mode {
    --cat-governance:   #0072B2; /* blue          */
    --cat-operations:   #009E73; /* bluish green   */
    --cat-diagnostics:  #E69F00; /* orange         */
    --cat-premium:      #CC79A7; /* reddish purple */
    --cat-intelligence: #56B4E9; /* sky blue       */
    --cat-config:       #999999; /* grey           */
    --cat-apply:        #D55E00; /* vermillion     */
}
/* slim-bar icons, tinted per category */
.nav-main-category.nc-governance   { color: var(--cat-governance); }
.nav-main-category.nc-operations   { color: var(--cat-operations); }
.nav-main-category.nc-diagnostics  { color: var(--cat-diagnostics); }
.nav-main-category.nc-premium      { color: var(--cat-premium); }
.nav-main-category.nc-intelligence { color: var(--cat-intelligence); }
.nav-main-category.nc-config       { color: var(--cat-config); }
.nav-main-category.nc-apply        { color: var(--cat-apply); }
/* active slim-bar icon: keep the category colour for marker + glow */
.nav-main-category.active.nc-governance   { color: var(--cat-governance);   background-color: rgba(255,255,255,0.06); box-shadow: inset 2px 0 0 var(--cat-governance); }
.nav-main-category.active.nc-operations   { color: var(--cat-operations);   background-color: rgba(255,255,255,0.06); box-shadow: inset 2px 0 0 var(--cat-operations); }
.nav-main-category.active.nc-diagnostics  { color: var(--cat-diagnostics);  background-color: rgba(255,255,255,0.06); box-shadow: inset 2px 0 0 var(--cat-diagnostics); }
.nav-main-category.active.nc-premium      { color: var(--cat-premium);      background-color: rgba(255,255,255,0.06); box-shadow: inset 2px 0 0 var(--cat-premium); }
.nav-main-category.active.nc-intelligence { color: var(--cat-intelligence); background-color: rgba(255,255,255,0.06); box-shadow: inset 2px 0 0 var(--cat-intelligence); }
.nav-main-category.active.nc-config       { color: var(--cat-config);       background-color: rgba(255,255,255,0.06); box-shadow: inset 2px 0 0 var(--cat-config); }
.nav-main-category.active.nc-apply        { color: var(--cat-apply);        background-color: rgba(255,255,255,0.06); box-shadow: inset 2px 0 0 var(--cat-apply); }
/* expanded pane: category title + section-label headings in the category colour */
.nav-cat--governance   .nav-brand-text, .nav-cat--governance   .nav-section-label { color: var(--cat-governance); }
.nav-cat--operations   .nav-brand-text, .nav-cat--operations   .nav-section-label { color: var(--cat-operations); }
.nav-cat--diagnostics  .nav-brand-text, .nav-cat--diagnostics  .nav-section-label { color: var(--cat-diagnostics); }
.nav-cat--premium      .nav-brand-text, .nav-cat--premium      .nav-section-label { color: var(--cat-premium); }
.nav-cat--intelligence .nav-brand-text, .nav-cat--intelligence .nav-section-label { color: var(--cat-intelligence); }
.nav-cat--config       .nav-brand-text, .nav-cat--config       .nav-section-label { color: var(--cat-config); }
.nav-cat--apply        .nav-brand-text, .nav-cat--apply        .nav-section-label { color: var(--cat-apply); }
</style>

@code {
    private string _activeCategory = "Governance";

    private void SetCategory(string category)
    {
        _activeCategory = category;
        if (_collapsed) _collapsed = false; // Auto-expand when picking a category
    }

    private bool _performanceMonitorExists = false;
    private bool _SQLWATCHExists = false;

    // ── Bundle tier badge ────────────────────────────────────────────────
    private SQLTriage.Data.Services.Licensing.Tier _bundleTier = SQLTriage.Data.Services.Licensing.Tier.Free;
    private bool _bundleUnlocked = false;
    private bool _consolidationUnlocked = false;

    private string _badgeClass =>
        !_bundleUnlocked                                                           ? "not-activated"
        : _bundleTier == SQLTriage.Data.Services.Licensing.Tier.Full              ? "full"
        :                                                                            "free";

    private string _badgeText =>
        !_bundleUnlocked                                                           ? "Not Activated"
        : _bundleTier == SQLTriage.Data.Services.Licensing.Tier.Full              ? "Full"
        :                                                                            "Free";

    private string _badgeTitle =>
        !_bundleUnlocked
            ? "Bundle failed to load — check app log. Click for Settings."
            : _bundleTier == SQLTriage.Data.Services.Licensing.Tier.Full
                ? "Full Audit active — click to manage"
                : "Free tier — click for Settings";

    private void GoToTierSettings() => Navigation.NavigateTo("/settings");

    [Inject] private NavigationManager Navigation { get; set; } = default!;

    // ── Sidebar collapse ─────────────────────────────────────────────────
    private bool _collapsed = false;
    private bool _showAdvanced = false;
    private bool _showConfigure = false;
    private void ToggleCollapse() => _collapsed = !_collapsed;

    // Dev-tools visibility is build-time now (BuildModules.DevTools) — the old
    // MachineName=="MSI"/UserName=="afsul" gate is replaced by build-absence:
    // community builds compile those pages out entirely (buildprofile.targets).

    // ── No-Pants Mode ────────────────────────────────────────────────────
    private bool _noPantsMode = false;
    private bool _showNoPantsModal = false;

    private void ToggleNoPantsMode(bool v)
    {
        _noPantsMode = v;
        if (!RbacService.HasPermission(UserState.Role, "run_scripts"))
            return;

        if (_noPantsMode)
        {
            if (!UserSettings.GetNoPantsDisclaimerAccepted())
            {
                _showNoPantsModal = true;
                return;
            }
            _noPantsMode = true;
            UserSettings.SetNoPantsMode(true);
            AuditLog.LogSecurityEvent(
                $"No-Pants Mode ENABLED by {Environment.UserName}",
                AuditSeverity.Warning,
                new Dictionary<string, string> { ["User"] = Environment.UserName, ["Action"] = "Enabled" });
        }
        else
        {
            _noPantsMode = false;
            UserSettings.SetNoPantsMode(false);
            AuditLog.LogSecurityEvent(
                $"No-Pants Mode DISABLED by {Environment.UserName}",
                AuditSeverity.Info,
                new Dictionary<string, string> { ["User"] = Environment.UserName, ["Action"] = "Disabled" });
        }
    }

    private void AcceptNoPantsDisclaimer()
    {
        _showNoPantsModal = false;
        _noPantsMode = true;
        UserSettings.SetNoPantsDisclaimerAccepted(true);
        UserSettings.SetNoPantsMode(true);
        AuditLog.LogSecurityEvent(
            $"No-Pants Mode disclaimer ACCEPTED and ENABLED by {Environment.UserName}",
            AuditSeverity.Warning,
            new Dictionary<string, string> { ["User"] = Environment.UserName, ["Action"] = "DisclaimerAccepted" });
    }

    private void CancelNoPantsModal()
    {
        _showNoPantsModal = false;
    }

    // ── Report / Feedback popover ────────────────────────────────────────
    // Feedback moved to the bottom status bar (StatusBar.razor).

    // ── Experimental Mode ─────────────────────────────────────────────────
    private bool _experimentalMode = false;
    private bool _showMaturityRoadmap = false;

    private void ToggleExperimentalMode(bool v)
    {
        _experimentalMode = v;
        UserSettings.SetExperimentalMode(_experimentalMode);
    }

    // ── Color-Blind Mode ──────────────────────────────────────────────────
    private bool _colorBlindMode = false;

    private async Task ToggleColorBlindMode(bool v)
    {
        _colorBlindMode = v;
        UserSettings.SetColorBlindMode(_colorBlindMode);
        await ApplyColorBlindBodyClass();
    }

    private async Task ApplyColorBlindBodyClass()
    {
        try
        {
            await JS.InvokeVoidAsync("document.body.classList.toggle", "colorblind-mode", _colorBlindMode);
        }
        catch { /* JS not ready on first navigation — harmless */ }
    }

    // ── Narration (progressive disclosure: opinionated estate read on demand) ──
    private bool _narrationMode = false;

    private void ToggleNarrationMode(bool v)
    {
        _narrationMode = v;
        UserSettings.SetNarrationMode(_narrationMode);
    }

    // ── Notifications ─────────────────────────────────────────────────────
    private bool _notificationsEnabled = true;

    private void ToggleNotifications(bool v)
    {
        _notificationsEnabled = v;
        UserSettings.SetNotificationsEnabled(_notificationsEnabled);
        ToastService.Enabled = _notificationsEnabled;
    }

    protected override async Task OnInitializedAsync()
    {
        await UserState.InitAsync();
        
        _noPantsMode         = UserSettings.GetNoPantsMode();
        _experimentalMode    = UserSettings.GetExperimentalMode();
        _showMaturityRoadmap = UserSettings.GetShowMaturityRoadmap();
        _colorBlindMode      = UserSettings.GetColorBlindMode();
        _narrationMode       = UserSettings.GetNarrationMode();
        _notificationsEnabled = UserSettings.GetNotificationsEnabled();
        ToastService.Enabled  = _notificationsEnabled;   // sync service to persisted setting on startup
        _bundleTier          = Bundle.Tier;
        _bundleUnlocked      = Bundle.IsUnlocked;
        _consolidationUnlocked = ConsolidationModel.IsUnlocked;
        Bundle.BundleStateChanged                      += OnBundleStateChanged;
        FeatureGate.Changed                            += OnFeatureGateChanged;
        ConnectionManager.OnConnectionChanged          += OnServerChanged;
        ConnectionHealth.OnStatusChanged               += OnHealthChanged;
        UserSettings.OnShowMaturityRoadmapChanged      += OnMaturityRoadmapChanged;
        InstanceSelector.OnInstanceChanged             += OnInstanceChanged;
        
        QuickCheckState.StateChanged                   += OnStateChanged;
        FullAuditState.StateChanged                    += OnStateChanged;
        VaState.StateChanged                           += OnStateChanged;

        await RefreshDbFlags();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _colorBlindMode)
        {
            await ApplyColorBlindBodyClass();
        }
    }

    private void OnMaturityRoadmapChanged(bool enabled)
    {
        _showMaturityRoadmap = enabled;
        InvokeAsync(StateHasChanged);
    }

    private void OnHealthChanged() => InvokeAsync(StateHasChanged);

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void OnFeatureGateChanged(object? sender, EventArgs e) => InvokeAsync(StateHasChanged);

    private void OnBundleStateChanged(object? sender, EventArgs e)
    {
        _bundleTier     = Bundle.Tier;
        _bundleUnlocked = Bundle.IsUnlocked;
        _consolidationUnlocked = ConsolidationModel.IsUnlocked;
        InvokeAsync(StateHasChanged);
    }

    private void OnServerChanged()
    {
        DbAvailability.InvalidateCache();
        _ = InvokeAsync(async () =>
        {
            await RefreshDbFlags();
            StateHasChanged();
        });
    }

    private void OnInstanceChanged(string instanceName)
    {
        DbAvailability.InvalidateCache();
        _ = InvokeAsync(async () =>
        {
            await RefreshDbFlags();
            StateHasChanged();
        });
    }

    private async Task RefreshDbFlags()
    {
        var pmTask = DbAvailability.DatabaseExistsAsync("PerformanceMonitor");
        var swTask = DbAvailability.DatabaseExistsAsync("SQLWATCH");
        await Task.WhenAll(pmTask, swTask);
        _performanceMonitorExists = pmTask.Result;
        _SQLWATCHExists = swTask.Result;
    }

    private RenderFragment NavIcon(string? icon) => builder =>
    {
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "nav-icon");
        if (icon?.StartsWith("fa-") == true)
        {
            builder.OpenElement(2, "i");
            builder.AddAttribute(3, "class", icon);
            builder.CloseElement();
        }
        else
        {
            builder.AddContent(2, icon);
        }
        builder.CloseElement();
    };

    private (string Tier, string Tooltip)? GetDashboardLoadInfo(DashboardDefinition dash)
    {
        var panels = dash.Tabs != null && dash.Tabs.Count > 0
            ? dash.Tabs[0].Panels
            : dash.Panels;
        if (panels == null || panels.Count == 0) return null;

        double maxMs = 0;
        foreach (var panel in panels)
        {
            var m = PanelMetrics.GetMetric(panel.Id);
            if (m != null && m.P95Ms > 0)
            {
                if (m.P95Ms > maxMs) maxMs = m.P95Ms;
            }
            else if (panel.ExpectedLoadMs is double exp && exp > 0)
            {
                if (exp > maxMs) maxMs = exp;
            }
        }
        if (maxMs <= 0) return null;

        var label = maxMs < 1000 ? $"~{maxMs:F0}ms" : $"~{maxMs / 1000.0:F1}s";
        var tier = maxMs < 500 ? "fast" : (maxMs < 1000 ? "med" : "slow");
        return (tier, $"Expected load (p95): {label}");
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        Bundle.BundleStateChanged                  -= OnBundleStateChanged;
        FeatureGate.Changed                        -= OnFeatureGateChanged;
        ConnectionManager.OnConnectionChanged      -= OnServerChanged;
        ConnectionHealth.OnStatusChanged           -= OnHealthChanged;
        UserSettings.OnShowMaturityRoadmapChanged  -= OnMaturityRoadmapChanged;
        InstanceSelector.OnInstanceChanged         -= OnInstanceChanged;
        
        QuickCheckState.StateChanged               -= OnStateChanged;
        FullAuditState.StateChanged                -= OnStateChanged;
        VaState.StateChanged                       -= OnStateChanged;

        await ValueTask.CompletedTask;
    }
}
