@inject NavigationManager Navigation
@inject SQLTriage.Data.Services.IFeatureGate FeatureGate

@if (_isOpen)
{
    <div class="cmd-overlay" @onclick="Close">
        <div class="cmd-palette" @onclick:stopPropagation @onclick="(() => {})" @onkeydown="HandleKeyDown">
            <div class="cmd-input-wrapper">
                <i class="fa-solid fa-search cmd-search-icon"></i>
                <input @ref="_searchInput" class="cmd-input" type="text" placeholder="Search pages... (Ctrl+K)" @bind="_query" @bind:event="oninput" @onkeydown="HandleKeyDown" />
            </div>
            <div class="cmd-results">
                @foreach (var item in _filteredPages)
                {
                    var index = _filteredPages.IndexOf(item);
                    <div class="cmd-item @(_selectedIndex == index ? "cmd-item-selected" : "")" @onclick="() => NavigateTo(item.Route)" @onmouseenter="() => _selectedIndex = index">
                        <span class="cmd-item-icon"><i class="@item.Icon"></i></span>
                        <span class="cmd-item-label">@item.Label</span>
                        <span class="cmd-item-hint">@item.Hint</span>
                    </div>
                }
                @if (_filteredPages.Count == 0)
                {
                    <div class="cmd-item cmd-item-empty">No pages match "@_query"</div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _isOpen;
    private string _query = "";
    private int _selectedIndex;
    private List<PalettePage> _allPages = new();
    private List<PalettePage> _filteredPages = new();
    private ElementReference _searchInput;

    public static Action? RequestOpen;

    [Microsoft.JSInterop.JSInvokable("OpenCommandPalette")]
    public static void JSOpenCommandPalette()
    {
        RequestOpen?.Invoke();
    }

    protected override void OnInitialized()
    {
        RequestOpen = Open;

        // Entries are gated by build-profile module presence (BuildModules consts) so a
        // community build offers no dead routes. The old MSI/afsul maintainer-workstation
        // gate is gone: governance pages ship to everyone now (they're the headline free
        // feature), and dev-tools are build-absent instead of machine-hidden.
        _allPages = new List<PalettePage>
        {
            new("CIO Dashboard", "/cio", "fa-solid fa-crown", "Executive overview"),
            new("Governance Scoring", "/governance", "fa-solid fa-scale-balanced", "Health assessment"),
            new("Compliance Map", "/compliance-map", "fa-solid fa-shield-halved", "Framework coverage"),
            new("Compliance Roadmap", "/diagnostics-roadmap", "fa-solid fa-road", "Maturity levels"),
            new("Remediation Playbooks", "/playbooks", "fa-solid fa-book-medical", "Actionable guidance"),
            new("Audit Assessment", "/audit", "fa-solid fa-bolt", "Run the framework-mapped check corpus"),
            new("Raw Diagnostics", "/fullaudit", "fa-solid fa-magnifying-glass-chart", "Diagnostic .sql scripts → CSV"),
            new("Servers", "/servers", "fa-solid fa-server", "Connection management"),
            new("Index Analysis", "/index-analysis", "fa-solid fa-list-ol", "Missing/unused/fragmented"),
            new("Audit Log", "/audit-log", "fa-solid fa-clipboard-list", "Security events"),
            new("Settings", "/settings", "fa-solid fa-gear", "Configuration"),
            new("Blocking Forensics", "/blocking-forensics", "fa-solid fa-link-slash", "Blocking history timeline"),
            new("Code Hotspots", "/code-hotspots", "fa-solid fa-fire", "Query patterns"),
            new("Capacity", "/capacity", "fa-solid fa-chart-line", "Forecasting"),
            new("Guide", "/guide", "fa-solid fa-compass", "Navigation help"),
            new("About", "/about", "fa-solid fa-circle-info", "App info"),
            new("Vulnerability", "/vulnerabilityassessment", "fa-solid fa-bug", "Security scan"),
            new("Benchmark", "/benchmark", "fa-solid fa-gauge-high", "Performance tests"),
        };
        if (BuildModules.DevTools)
        {
            // runtime layer: full builds list dev-tools only with the bundle dev-capability claim
            if (FeatureGate.IsEnabled(FeatureRegistrar.DevTools))
            {
                _allPages.Add(new("Cost Tuner", "/remediation-tuner", "fa-solid fa-sliders", "Tune check effort hours"));
            }
        }
        if (BuildModules.Operations)
        {
            _allPages.Add(new("Environment", "/environment", "fa-solid fa-leaf", "Instance overview"));
            _allPages.Add(new("Alerts", "/alerts", "fa-solid fa-bell", "Alert management"));
            _allPages.Add(new("Alerting Config", "/alerting-config", "fa-solid fa-sliders", "Notification channels"));
            _allPages.Add(new("NOC Board", "/alerts-noc", "fa-solid fa-tv", "Alert wallboard"));
            _allPages.Add(new("Scheduled Tasks", "/scheduled-tasks", "fa-solid fa-clock", "Automation"));
            _allPages.Add(new("Service Management", "/service-management", "fa-solid fa-wrench", "Windows services"));
            _allPages.Add(new("Deploy SQLWATCH", "/deploysqlwatch", "fa-solid fa-rocket", "Monitoring setup"));
        }
        if (BuildModules.LiveMonitoring)
        {
            _allPages.Add(new("Wait Events", "/waitevents", "fa-solid fa-hourglass-half", "Performance waits"));
            _allPages.Add(new("Long Queries", "/longqueries", "fa-solid fa-timeline", "Expensive queries"));
            _allPages.Add(new("Memory", "/memory", "fa-solid fa-memory", "Memory health"));
            _allPages.Add(new("Live Monitor", "/dashboard/live", "fa-solid fa-heart-pulse", "Real-time metrics"));
        }
        _filteredPages = _allPages;
    }

    private void OnQueryChanged()
    {
        _filteredPages = string.IsNullOrWhiteSpace(_query)
            ? _allPages
            : _allPages.Where(p => (p.Label + " " + p.Hint).Contains(_query, StringComparison.OrdinalIgnoreCase)).ToList();
        _selectedIndex = 0;
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") { Close(); }
        else if (e.Key == "ArrowDown") { _selectedIndex = Math.Min(_selectedIndex + 1, _filteredPages.Count - 1); }
        else if (e.Key == "ArrowUp") { _selectedIndex = Math.Max(_selectedIndex - 1, 0); }
        else if (e.Key == "Enter" && _filteredPages.Count > 0) { NavigateTo(_filteredPages[_selectedIndex].Route); }
        else { OnQueryChanged(); return; }
        InvokeAsync(StateHasChanged);
    }

    private void NavigateTo(string route) { Close(); Navigation.NavigateTo(route); }
    private async void Open() 
    { 
        _isOpen = true; 
        _query = ""; 
        _selectedIndex = 0; 
        _filteredPages = _allPages; 
        await InvokeAsync(StateHasChanged); 
        await Task.Delay(50);
        try { await _searchInput.FocusAsync(); } catch { }
    }
    private void Close() { _isOpen = false; InvokeAsync(StateHasChanged); }

    private record PalettePage(string Label, string Route, string Icon, string Hint);
}
