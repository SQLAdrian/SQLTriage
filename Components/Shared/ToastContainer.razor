<!--/* In the name of God, the Merciful, the Compassionate */-->
@using Microsoft.AspNetCore.Components
@using SQLTriage.Data
@using SQLTriage.Data.Services
@inject ToastService ToastService
@implements IDisposable

<div class="toast-container">
    @* Toast stack — renders bottom-up via flex-direction:column-reverse *@
    @foreach (var toast in _toasts)
    {
        <div class="toast toast-@toast.Type.ToString().ToLower() @(toast.IsVisible ? "show" : "") @(toast.IsAlert ? "toast-alert-size" : "")"
             @key="toast.Id">
            <i class="toast-icon @GetIcon(toast.Type)"></i>
            <div class="toast-content">
                <div class="toast-title">@toast.Title</div>
                @if (!string.IsNullOrEmpty(toast.Message))
                {
                    <div class="toast-message">@toast.Message</div>
                }
            </div>
            <button class="toast-close" @onclick="() => RemoveToast(toast.Id)">&times;</button>
        </div>
    }
</div>

@* Floating bottom-right status badges removed 2026-05-29 (CLIPPY redesign):
   the red No-Pants FAB and the mute badge were distracting clutter. No-Pants
   state is shown by its nav switch; notifications now have a dedicated nav
   switch (NavMenu → bottom toggle group). Flood-muting still works silently;
   it just no longer paints a floating badge. *@

@code {
    private List<ToastNotification> _toasts = new();

    // Flood detection: track how many alert toasts arrived in the last 5 seconds
    private readonly System.Collections.Generic.Queue<DateTime> _recentAlerts = new();
    private const int FloodThreshold = 5;
    private const int FloodWindowSeconds = 5;

    protected override void OnInitialized()
    {
        ToastService.OnShow += ShowToast;
    }

    private void ShowToast(ToastNotification toast)
    {
        InvokeAsync(() =>
        {
            if (toast.IsAlert)
            {
                // Flood detection
                var now = DateTime.UtcNow;
                _recentAlerts.Enqueue(now);
                while (_recentAlerts.Count > 0 && (now - _recentAlerts.Peek()).TotalSeconds > FloodWindowSeconds)
                    _recentAlerts.Dequeue();

                if (_recentAlerts.Count >= FloodThreshold && !ToastService.IsMuted)
                {
                    // Toast storm — silently mute alerts for 5 min. (The old
                    // floating "muted" badge was removed in the CLIPPY redesign;
                    // the nav Notifications switch is the user-facing control.)
                    ToastService.MuteFor(5);
                    return; // don't show this toast — already muted
                }
            }

            _toasts.Add(toast);
            toast.IsVisible = true;
            StateHasChanged();

            _ = Task.Delay(toast.Duration).ContinueWith(_ =>
                InvokeAsync(() => RemoveToast(toast.Id)));
        });
    }

    private void RemoveToast(string id)
    {
        var toast = _toasts.FirstOrDefault(t => t.Id == id);
        if (toast != null)
        {
            toast.IsVisible = false;
            StateHasChanged();
            _ = Task.Delay(300).ContinueWith(_ =>
                InvokeAsync(() =>
                {
                    _toasts.Remove(toast);
                    StateHasChanged();
                }));
        }
    }

    private static string GetIcon(ToastType type) => type switch
    {
        ToastType.Success => "fa-solid fa-check",
        ToastType.Error   => "fa-solid fa-xmark",
        ToastType.Warning => "fa-solid fa-triangle-exclamation",
        ToastType.Info    => "fa-solid fa-circle-info",
        _                 => "fa-solid fa-circle-info"
    };

    public void Dispose()
    {
        ToastService.OnShow -= ShowToast;
    }
}
