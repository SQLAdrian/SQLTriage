<!--/* In the name of God, the Merciful, the Compassionate */-->
@using System.Data

@using System.Linq

<div class="bg-app-bg-panel rounded-lg overflow-hidden my-2" role="region" aria-label="@(string.IsNullOrEmpty(Title) ? "Data table" : Title)">
    @if (!string.IsNullOrEmpty(Title))
    {
        <div class="text-sm font-semibold px-4 pt-3 pb-2 text-app-text-primary" id="@($"grid-title-{Title.GetHashCode()}")">
            <span>@Title</span>
            @if (TopRowsConfig.HasValue)
            {
                <span class="ml-4 text-xs">
                    Top <input type="number"
                               class="w-16 px-2 py-1 bg-app-bg-primary border border-app-border rounded text-app-text-primary text-xs"
                               value="@_topRowsInput"
                               min="1"
                               max="1000"
                               title="Number of rows to fetch"
                               @onchange="HandleTopRowsChange"
                               @onclick:stopPropagation />
                </span>
            }
        </div>
    }

    @if (Data != null && Data.Rows.Count > 0)
    {
        <div class="overflow-x-auto max-h-100 overflow-y-auto" tabindex="0">
            <table class="w-full border-collapse text-sm" role="table" aria-labelledby="@($"grid-title-{Title.GetHashCode()}")">
                <thead>
                    <tr role="row">
                        @if (!string.IsNullOrEmpty(PlanIndicatorColumn) && Data.Columns.Contains(PlanIndicatorColumn))
                        {
                            <th role="columnheader" class="w-12 px-3 py-2 text-left text-xs font-semibold text-app-text-secondary bg-app-bg-secondary border-b border-app-border">Plan</th>
                        }
                        @foreach (DataColumn col in Data.Columns)
                        {
                            @if (HiddenColumns == null || !HiddenColumns.Contains(col.ColumnName))
                            {
                                <th @onclick="() => SortBy(col.ColumnName)"
                                    role="columnheader"
                                    tabindex="0"
                                    @onkeydown="@(e => HandleHeaderKeyDown(e, col.ColumnName))"
                                    aria-sort="@GetAriaSortValue(col.ColumnName)"
                                    class="px-3 py-2 text-left text-xs font-semibold text-app-text-secondary bg-app-bg-secondary border-b border-app-border cursor-pointer select-none hover:text-app-text-primary @(SortColumn == col.ColumnName ? "text-app-accent" : "")">
                                    @col.ColumnName
                                    @if (SortColumn == col.ColumnName)
                                    {
                                        <span aria-hidden="true">@(SortAscending ? " ▲" : " ▼")</span>
                                    }
                                </th>
                            }
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in GetSortedRows())
                    {
                        <tr @onclick="() => HandleRowClick(row)"
                            role="row"
                            tabindex="@(IsClickable ? "0" : "-1")"
                            @onkeydown="@(e => HandleRowKeyDown(e, row))"
                            class="@(IsClickable ? "cursor-pointer" : "") hover:bg-app-bg-hover">
                            @if (!string.IsNullOrEmpty(PlanIndicatorColumn) && Data.Columns.Contains(PlanIndicatorColumn))
                            {
                                var hasPlan = row[PlanIndicatorColumn] != DBNull.Value && !string.IsNullOrWhiteSpace(row[PlanIndicatorColumn]?.ToString());
                                <td role="cell" class="w-12 px-3 py-2 border-b border-app-border">
                                    @if (hasPlan)
                                    {
                                        <span class="bg-app-accent/20 text-app-accent px-2 py-0.5 rounded text-xs" title="Click row to view plan"><i class="fa-solid fa-clipboard-list"></i></span>
                                    }
                                </td>
                            }
                            @foreach (DataColumn col in Data.Columns)
                            {
                                @if (HiddenColumns == null || !HiddenColumns.Contains(col.ColumnName))
                                {
                                    <td role="cell" class="px-3 py-2 border-b border-app-border text-app-text-primary max-w-xs overflow-hidden text-ellipsis whitespace-nowrap" title="@row[col]?.ToString()">
                                        @try
                                        {
                                            @FormatCell(row[col], col.ColumnName)
                                        }
                                        catch (Exception)
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                }
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-4 py-2 text-xs text-app-text-muted border-t border-app-border" role="status" aria-live="polite">
            @Data.Rows.Count row(s)
        </div>
    }
    else
    {
        <div class="text-center py-8 text-app-text-muted" role="status">No data available</div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public DataTable? Data
    {
        get => _data;
        set
        {
            if (_data != value)
            {
                _data = value;
                // Invalidate cache when data changes
                _cachedSortedRows = null;
            }
        }
    }
    [Parameter] public EventCallback<DataRow> OnRowClick { get; set; }
    [Parameter] public bool IsClickable { get; set; } = false;
    [Parameter] public int MaxRows { get; set; } = 500;
    [Parameter] public HashSet<string>? HiddenColumns { get; set; }
    [Parameter] public string? PlanIndicatorColumn { get; set; }
    [Parameter] public int? TopRowsConfig { get; set; }
    [Parameter] public EventCallback<int> OnTopRowsConfigChanged { get; set; }

    private DataTable? _data;
    private int _topRowsInput = 20;

    protected override void OnParametersSet()
    {
        if (TopRowsConfig.HasValue && TopRowsConfig.Value != _topRowsInput)
            _topRowsInput = TopRowsConfig.Value;
    }

    private async Task HandleTopRowsChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val) && val > 0)
        {
            _topRowsInput = val;
            if (OnTopRowsConfigChanged.HasDelegate)
                await OnTopRowsConfigChanged.InvokeAsync(val);
        }
    }

    private string? SortColumn;
    private bool SortAscending = true;
    
    // Cached sorted rows for performance
    private DataRow[]? _cachedSortedRows;
    private string? _lastSortColumn;
    private bool _lastSortAscending;

    private void SortBy(string column)
    {
        if (SortColumn == column)
        {
            SortAscending = !SortAscending;
        }
        else
        {
            SortColumn = column;
            SortAscending = true;
        }
        // Invalidate cache
        _cachedSortedRows = null;
    }

    private DataRow[] GetSortedRows()
    {
        if (Data == null || Data.Columns.Count == 0) return Array.Empty<DataRow>();
        
        // Return cached results if sort hasn't changed
        if (_cachedSortedRows != null && SortColumn == _lastSortColumn && SortAscending == _lastSortAscending)
        {
            // Verify cached rows are still valid for current DataTable
            if (_cachedSortedRows.Length > 0 && _cachedSortedRows[0].Table == Data)
            {
                return _cachedSortedRows;
            }
        }

        var rows = Data.AsEnumerable();
        if (!string.IsNullOrEmpty(SortColumn))
        {
            // Check if column exists before sorting
            if (Data.Columns.Contains(SortColumn))
            {
                rows = SortAscending
                    ? rows.OrderBy(r => r[SortColumn]?.ToString(), StringComparer.OrdinalIgnoreCase)
                    : rows.OrderByDescending(r => r[SortColumn]?.ToString(), StringComparer.OrdinalIgnoreCase);
            }
        }
        
        _cachedSortedRows = rows.Take(MaxRows).ToArray();
        _lastSortColumn = SortColumn;
        _lastSortAscending = SortAscending;
        
        return _cachedSortedRows;
    }

    private async Task HandleRowClick(DataRow row)
    {
        if (OnRowClick.HasDelegate)
            await OnRowClick.InvokeAsync(row);
    }

    private async Task HandleRowKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e, DataRow row)
    {
        if (e.Key == "Enter" || e.Key == " ")
        {
            await HandleRowClick(row);
        }
    }

    private void HandleHeaderKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e, string columnName)
    {
        if (e.Key == "Enter" || e.Key == " ")
        {
            SortBy(columnName);
        }
    }

    private string GetAriaSortValue(string columnName)
    {
        if (SortColumn != columnName) return "none";
        return SortAscending ? "ascending" : "descending";
    }

    private string FormatCell(object? value, string columnName)
    {
        if (value == null || value == DBNull.Value) return "";

        // Format duration columns
        if (columnName.Contains("duration", StringComparison.OrdinalIgnoreCase)
            || columnName.Contains("_ms", StringComparison.OrdinalIgnoreCase))
        {
            if (double.TryParse(value.ToString(), out var ms))
            {
                if (ms >= 60000) return $"{ms / 60000:F1}m";
                if (ms >= 1000) return $"{ms / 1000:F1}s";
                return $"{ms:F0}ms";
            }
        }

        var str = value.ToString() ?? "";
        return str.Length > 100 ? str[..100] + "..." : str;
    }
}
