<!--/* In the name of God, the Merciful, the Compassionate */-->
@using ApexCharts
@using SQLTriage.Data.Models
@using SQLTriage.Data.Services
@inject IChartThemeService ChartTheme
@implements IDisposable

<div class="chart-panel chart-panel--bar"
     role="img"
     aria-label="@(!string.IsNullOrEmpty(Title) ? $"Bar chart showing {Title}" : "Horizontal bar chart")">
    @if (!string.IsNullOrEmpty(Title))
    {
        <div class="chart-title">@Title</div>
    }

    @if (Data != null && Data.Any())
    {
        <ApexChart TItem="StatValue"
                   @key="_chartKey"
                   Height="@Height"
                   Options="@GetChartOptions()">
            <ApexPointSeries TItem="StatValue"
                             Items="@Data"
                             Name="@SeriesName"
                             SeriesType="SeriesType.Bar"
                             XValue="@(s => s.Label)"
                             YValue="@(s => (decimal)s.Value)" />
        </ApexChart>
    }
    else
    {
        <div class="chart-empty">No data available</div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public List<StatValue>? Data { get; set; }
    [Parameter] public int Height { get; set; } = 300;
    [Parameter] public string SeriesName { get; set; } = "Value";
    [Parameter] public string ValueSuffix { get; set; } = "";

    private string _chartKey = Guid.NewGuid().ToString();

    private ApexChartOptions<StatValue> GetChartOptions()
    {
        // Shared chrome (palette, dark theme, distributed horizontal bars, axis
        // K/M formatter, grid, legend off, data-labels off) comes from
        // ChartThemeService; only the value-suffix tooltip formatter lives here.
        var opts = ChartTheme.GetBarOptions<StatValue>("", "");

        opts.Tooltip.Y = new TooltipY
        {
            Formatter = "function(val) { return val != null ? val.toLocaleString() + '" + ValueSuffix + "' : ''; }"
        };

        return opts;
    }

    protected override void OnInitialized()
    {
        ChartTheme.OnChartThemeChanged += HandleThemeChanged;
    }

    // Force a chart re-create with the new palette when the user switches theme.
    private void HandleThemeChanged()
    {
        _chartKey = Guid.NewGuid().ToString();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ChartTheme.OnChartThemeChanged -= HandleThemeChanged;
    }
}
